// ========== Generated tests ==========

func Testbfs_level_order(t *testing.T) {
	let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_vertex(4);
g.add_edge(1, 2);
g.add_edge(1, 3);
g.add_edge(2, 4);

	
	let order = bfs(&g, 1);if order[0] != 1 { t.Errorf("got %v, want %v", order[0], 1) }if !(order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2) { t.Errorf("assertion failed: order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2") }if order[3] != 4 { t.Errorf("got %v, want %v", order[3], 4) }
}

func Testbfs_disconnected(t *testing.T) {
	let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

	
	if bfs(&g, 1) != vec![1] { t.Errorf("got %v, want %v", bfs(&g, 1), vec![1]) }
}

func Testbfs_single_node(t *testing.T) {
	let mut g = Graph::new(false);
g.add_vertex(42);

	
	if bfs(&g, 42) != vec![42] { t.Errorf("got %v, want %v", bfs(&g, 42), vec![42]) }
}

