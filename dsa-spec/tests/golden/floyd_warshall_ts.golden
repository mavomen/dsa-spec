// ========== Generated Jest tests ==========

describe('three_vertex_graph', () => {
    it('should work', () => {
        // Setup
        let n = 3;
        // Actions
        let mut graph = vec![vec![None; n]; n];graph[0][0] = Some(0); graph[0][1] = Some(3); graph[0][2] = Some(8);graph[1][0] = Some(3); graph[1][1] = Some(0); graph[1][2] = Some(1);graph[2][0] = Some(8); graph[2][1] = Some(1); graph[2][2] = Some(0);let dist = floyd_warshall(&graph);
        // Assertions
        expect(dist[0][1]).toBe(Some(3));expect(dist[0][2]).toBe(Some(4));expect(dist[1][2]).toBe(Some(1));expect(dist[2][0]).toBe(Some(4));expect(dist[0][0]).toBe(Some(0));
    });
});

describe('single_vertex', () => {
    it('should work', () => {
        // Setup
        let n = 1;
        // Actions
        let graph = vec![vec![Some(0)]];let dist = floyd_warshall(&graph);
        // Assertions
        expect(dist[0][0]).toBe(Some(0));
    });
});

describe('disconnected_vertices', () => {
    it('should work', () => {
        // Setup
        let n = 4;
        // Actions
        let mut graph = vec![vec![None; n]; n];graph[0][0] = Some(0); graph[0][1] = Some(2);graph[1][0] = Some(2); graph[1][1] = Some(0);graph[2][2] = Some(0);graph[3][3] = Some(0);let dist = floyd_warshall(&graph);
        // Assertions
        expect(dist[0][1]).toBe(Some(2));expect(dist[0][2].is_none()).toBe(true);expect(dist[2][3].is_none()).toBe(true);
    });
});

