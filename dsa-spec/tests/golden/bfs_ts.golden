// ========== Generated Jest tests ==========

describe('bfs_level_order', () => {
    it('should work', () => {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_vertex(4);
g.add_edge(1, 2);
g.add_edge(1, 3);
g.add_edge(2, 4);

        // Actions
        
        // Assertions
        let order = bfs(&g, 1);;expect(order[0]).toBe(1);expect(order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2).toBe(true);expect(order[3]).toBe(4);
    });
});

describe('bfs_disconnected', () => {
    it('should work', () => {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

        // Actions
        
        // Assertions
        expect(bfs(&g, 1)).toBe(vec![1]);
    });
});

describe('bfs_single_node', () => {
