// --- CircularBuffer.ts ---
/**
 * CircularBuffer
 * Time complexity: O(1) enqueue/dequeue

 * Space complexity: O(n)


 * Invariants:
 * - length <= capacity
 * - 0 <= head < capacity
 * - 0 <= tail < capacity

 */


export class CircularBuffer<T> {

    
    public buffer: (T | null)[];
    
    public head: number;
    
    public tail: number;
    
    public size: number;
    
    public capacity: number;
    
}

// --- CircularBuffer_new.ts ---
/**
 * CircularBuffer.new
 * @param capacity - number

 * @returns Self


 * Preconditions:
 * - capacity > 0


 * Postconditions:
 * - is_empty() == true
 * - capacity == capacity

 */

import { CircularBuffer } from './circularbuffer';


(CircularBuffer.prototype as any).new = function <T>(capacity: number): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('enqueue_dequeue_fifo', () => {
    it('should pass', () => {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);
        expect(buf.dequeue()).toBe(Some(1));expect(buf.dequeue()).toBe(Some(2));
    });
});

describe('full_buffer_prevents_enqueue', () => {
    it('should pass', () => {
        let mut buf = CircularBuffer::new(1);
        buf.enqueue(42);
        expect(buf.is_full()).toBe(true);expect(buf.enqueue(43).is_err()).toBe(true);
    });
});

describe('empty_buffer_returns_none', () => {
    it('should pass', () => {
        let buf = CircularBuffer::<i32>::new(5);
        
        expect(buf.dequeue()).toBe(None);
    });
});

describe('wrap_around_works', () => {
    it('should pass', () => {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);buf.dequeue();buf.enqueue(3);buf.enqueue(4);
        expect(buf.dequeue()).toBe(Some(2));expect(buf.dequeue()).toBe(Some(3));expect(buf.dequeue()).toBe(Some(4));
    });
});


