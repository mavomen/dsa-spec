/**
 * CircularBuffer

 * Time complexity: O(1) enqueue/dequeue


 * Space complexity: O(n)


 * Invariants:

 * - length <= capacity

 * - 0 <= head < capacity

 * - 0 <= tail < capacity


 */



export interface CircularBuffer<T extends Clone & Default> {
    
    buffer: (T | null)[];
    
    head: number;
    
    tail: number;
    
    size: number;
    
    capacity: number;
    
}

export class CircularBufferImpl<T extends Clone & Default> implements CircularBuffer<T> {
    constructor(
        
        public buffer: (T | null)[],
        
        public head: number,
        
        public tail: number,
        
        public size: number,
        
        public capacity: number
        
    ) {}

    
    /**
     * new
     
     * Preconditions:
      * - capacity > 0
     
     
     * Postconditions:
      * - is_empty() == true
      * - capacity == capacity
     
     
     */
    new(capacity: number): Self {
        
        // TODO: Implement new
        throw new Error('Not implemented');
    }
    
    /**
     * enqueue
     
     * Preconditions:
      * - size < capacity
     
     
     * Postconditions:
      * - size == old.size + 1
     
     
     * @throws Error (from Result type)
     
     */
    enqueue(item: T): () {
        
        // TODO: Implement enqueue
        throw new Error('Not implemented');
    }
    
    /**
     * dequeue
     
     * Preconditions:
      * - size > 0
     
     
     * Postconditions:
      * - size == old.size - 1
     
     
     */
    dequeue(): T | null {
        
