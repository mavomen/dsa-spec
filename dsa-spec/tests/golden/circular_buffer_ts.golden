}



// ========== Generated Jest tests ==========

describe('enqueue_dequeue_fifo', () => {
    it('should work', () => {
        // Setup
        let mut buf = CircularBuffer::new(3);
        // Actions
        buf.enqueue(1);buf.enqueue(2);
        // Assertions
        expect(buf.dequeue()).toBe(Some(1));expect(buf.dequeue()).toBe(Some(2));
    });
});

describe('full_buffer_prevents_enqueue', () => {
    it('should work', () => {
        // Setup
        let mut buf = CircularBuffer::new(1);
        // Actions
        buf.enqueue(42);
        // Assertions
        expect(buf.is_full()).toBe(true);expect(buf.enqueue(43).is_err()).toBe(true);
    });
});

describe('empty_buffer_returns_none', () => {
    it('should work', () => {
        // Setup
        let buf = CircularBuffer::<i32>::new(5);
        // Actions
        
        // Assertions
        expect(buf.dequeue()).toBe(None);
    });
});

describe('wrap_around_works', () => {
    it('should work', () => {
        // Setup
        let mut buf = CircularBuffer::new(3);
        // Actions
        buf.enqueue(1);buf.enqueue(2);buf.dequeue();buf.enqueue(3);buf.enqueue(4);
        // Assertions
        expect(buf.dequeue()).toBe(Some(2));expect(buf.dequeue()).toBe(Some(3));expect(buf.dequeue()).toBe(Some(4));
    });
});

