// ========== Generated xUnit tests ==========

public class simple_graph_mstTests
{
    [Fact]
    public void simple_graph_mst_Test()
    {
        // Setup
        let vertices = 4;
        // Actions
        let edges = vec![(0, 1, 10), (0, 2, 6), (0, 3, 5), (1, 3, 15), (2, 3, 4)];let mst = kruskal(vertices, edges);
        // Assertions
        Assert.AreEqual(mst.len(), 3);Assert.AreEqual(total_weight(&mst), 19);
    }
}

public class single_vertexTests
{
    [Fact]
    public void single_vertex_Test()
    {
        // Setup
        let vertices = 1;
        // Actions
        let edges: Vec<(usize, usize, usize)> = vec![];let mst = kruskal(vertices, edges);
        // Assertions
        Assert.AreEqual(mst.len(), 0);
    }
}

public class disconnected_graphTests
{
    [Fact]
    public void disconnected_graph_Test()
    {
        // Setup
        let vertices = 3;
        // Actions
        let edges = vec![(0, 1, 5)];let mst = kruskal(vertices, edges);
        // Assertions
        Assert.AreEqual(mst.len(), 1);
    }
}

}
