// --- BSTNode.py ---
"""
BinarySearchTree
Time complexity: O(log n) average, O(n) worst
Space complexity: O(n)

Invariants:
    - left.value < node.value < right.value
    - no duplicate values

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict


T = TypeVar('T')



@dataclass
class BSTNode(Generic[T]):
    """BinarySearchTree"""
    
    value: T
    
    left: Optional[BSTNode<T>]
    
    right: Optional[BSTNode<T>]
    

// --- BSTNode_new.py ---
"""
BinarySearchTree.new


Postconditions:
    - root is None

"""

from bstnode import BSTNode


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


BSTNode.new = new

del new


# ========== Generated tests ==========

def test_insert_and_contains():
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)
    assert bst.contains(5)assert bst.contains(3)assert bst.contains(7)assert !bst.contains(10)

def test_inorder_returns_sorted():
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)bst.insert(1)bst.insert(9)
    assert bst.inorder() == vec![1, 3, 5, 7, 9]

def test_duplicate_insert_returns_false():
    let mut bst = BinarySearchTree::new();
    bst.insert(10)
    assert bst.insert(10) == false


