# ========== Generated pytest tests ==========

def test_insert_and_contains():
    """Test: insert_and_contains"""
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)
    assert bst.contains(5)assert bst.contains(3)assert bst.contains(7)assert !bst.contains(10)

def test_inorder_returns_sorted():
    """Test: inorder_returns_sorted"""
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)bst.insert(1)bst.insert(9)
    assert bst.inorder() == vec![1, 3, 5, 7, 9]

def test_duplicate_insert_returns_false():
    """Test: duplicate_insert_returns_false"""
    let mut bst = BinarySearchTree::new();
    bst.insert(10)
    assert bst.insert(10) == false


if __name__ == "__main__":
    pytest.main([__file__])
