// --- AVLNode.cs ---
/// <summary>
/// AVLTree

/// Time complexity: O(log n) search/insert/delete


/// Space complexity: O(n)


/// Invariants:

/// - left.value < node.value < right.value

/// - |left.height - right.height| <= 1

/// - height = 1 + max(left.height, right.height)


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace AVLTree
{
    public partial class AVLNode<T>
    where T : Ord, Clone

    {
        
        public T Value { get; set; }
        
        public AVLNode<T>? Left { get; set; }
        
        public AVLNode<T>? Right { get; set; }
        
        public int Height { get; set; }
        
    }
}

// --- AVLNode.New.cs ---
namespace AVLTree
{
    public partial class AVLNode<T>
    where T : Ord, Clone

    {
        /// <summary>
        /// New.
        /// </summary>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - root is None
        
        /// </remarks>
        
        
        public Self New()
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class AVLNodeinsert_maintains_balanceTests
{
    [Fact]
    public void insert_maintains_balance_Test()
    {
        let mut avl = AVLTree::new();
        avl.insert(1);avl.insert(2);avl.insert(3);
        Assert.IsTrue(avl.contains(2));Assert.AreEqual(avl.height(), 2);Assert.AreEqual(avl.inorder(), vec![1, 2, 3]);
    }
}

public class AVLNodeleft_heavy_rebalanceTests
{
    [Fact]
    public void left_heavy_rebalance_Test()
    {
        let mut avl = AVLTree::new();
        avl.insert(3);avl.insert(2);avl.insert(1);
        Assert.AreEqual(avl.height(), 2);Assert.AreEqual(avl.inorder(), vec![1, 2, 3]);
    }
}

public class AVLNodemultiple_inserts_stay_balancedTests
{
    [Fact]
    public void multiple_inserts_stay_balanced_Test()
    {
        let mut avl = AVLTree::new();
        avl.insert(10);avl.insert(20);avl.insert(30);avl.insert(40);avl.insert(50);avl.insert(25);
        Assert.IsTrue(avl.height() <= 3);
    }
}


