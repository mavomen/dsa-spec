// --- Node.rs ---
/// SinglyLinkedList
/// Time complexity: O(1) prepend, O(n) append/search

/// Space complexity: O(n)

/// Invariants:
/// - no cycles
/// - head is None iff tail is None

#[derive(Debug, Clone)]
pub struct Node<T>
where
    T: Clone,
{
    pub value: T,

    pub next: Option<Box<Node<T>>>,
}

impl<T> Node<T> {
    pub fn new() -> Self {
        Self {
            value: Default::default(),

            next: Default::default(),
        }
    }
}

// --- Node_new.rs ---
/// SinglyLinkedList.new

/// Returns: Self

/// Postconditions:
/// - head is None

impl<T> Node<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn prepend_pop_front() {
        let mut list = SinglyLinkedList::new();
        list.prepend(1);
        list.prepend(2);
        assert_eq!(list.pop_front(), Some(2));
        assert_eq!(list.pop_front(), Some(1));
    }

    #[test]
    fn append_order() {
        let mut list = SinglyLinkedList::new();
        list.append(1);
        list.append(2);
        assert_eq!(list.pop_front(), Some(1));
    }

    #[test]
    fn pop_front_empty() {
        let list = SinglyLinkedList::<i32>::new();

        assert_eq!(list.pop_front(), None);
    }
}

