// --- Node_pop_front.rs ---
/// SinglyLinkedList.pop_front

/// Returns: Option<T>

/// Preconditions:
/// - !is_empty()

/// Postconditions:
/// - head == old.head.next

impl<T> Node<T> {
    pub fn pop_front(&mut self) -> Option<T> {
        todo!()
    }
}

