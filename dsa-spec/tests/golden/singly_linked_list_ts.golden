// ========== Generated Jest tests ==========

describe('prepend_pop_front', () => {
    it('should work', () => {
        // Setup
        let mut list = SinglyLinkedList::new();
        // Actions
        list.prepend(1);list.prepend(2);
        // Assertions
        expect(list.pop_front()).toBe(Some(2));expect(list.pop_front()).toBe(Some(1));
    });
});

describe('append_order', () => {
    it('should work', () => {
        // Setup
        let mut list = SinglyLinkedList::new();
        // Actions
        list.append(1);list.append(2);
        // Assertions
        expect(list.pop_front()).toBe(Some(1));
    });
});

describe('pop_front_empty', () => {
    it('should work', () => {
        // Setup
        let list = SinglyLinkedList::<i32>::new();
        // Actions
        
        // Assertions
        expect(list.pop_front()).toBe(None);
    });
});

