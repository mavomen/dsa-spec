// --- Node.ts ---
/**
 * SinglyLinkedList
 * Time complexity: O(1) prepend, O(n) append/search

 * Space complexity: O(n)


 * Invariants:
 * - no cycles
 * - head is None iff tail is None

 */


export class Node<T> {

    
    public value: T;
    
    public next: Node<T> | null;
    
}

// --- Node_new.ts ---
/**
 * SinglyLinkedList.new

 * @returns Self



 * Postconditions:
 * - head is None

 */

import { Node } from './node';


(Node.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('prepend_pop_front', () => {
    it('should pass', () => {
        let mut list = SinglyLinkedList::new();
        list.prepend(1);list.prepend(2);
        expect(list.pop_front()).toBe(Some(2));expect(list.pop_front()).toBe(Some(1));
    });
});

describe('append_order', () => {
    it('should pass', () => {
        let mut list = SinglyLinkedList::new();
        list.append(1);list.append(2);
        expect(list.pop_front()).toBe(Some(1));
    });
});

describe('pop_front_empty', () => {
    it('should pass', () => {
        let list = SinglyLinkedList::<i32>::new();
        
        expect(list.pop_front()).toBe(None);
    });
});


