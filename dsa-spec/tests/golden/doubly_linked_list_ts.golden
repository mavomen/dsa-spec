// --- Node.ts ---
/**
 * DoublyLinkedList
 * Time complexity: O(1) insert/remove at head/tail, O(n) search

 * Space complexity: O(n)


 * Invariants:
 * - no cycles
 * - for each node, node.next.prev == node

 */


export class Node<T> {

    
    public value: T;
    
    public prev: Node<T> | null;
    
    public next: Node<T> | null;
    
}

// --- Node_new.ts ---
/**
 * DoublyLinkedList.new

 * @returns Self



 * Postconditions:
 * - head is None
 * - tail is None

 */

import { Node } from './node';


(Node.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('push_front_pop_front', () => {
    it('should pass', () => {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);list.push_front(2);
        expect(list.pop_front()).toBe(Some(2));expect(list.pop_front()).toBe(Some(1));
    });
});

describe('push_back_pop_back', () => {
    it('should pass', () => {
        let mut list = DoublyLinkedList::new();
        list.push_back(1);list.push_back(2);
        expect(list.pop_back()).toBe(Some(2));expect(list.pop_back()).toBe(Some(1));
    });
});

describe('mixed_operations', () => {
    it('should pass', () => {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);list.push_back(3);list.push_front(0);
        expect(list.pop_front()).toBe(Some(0));expect(list.pop_back()).toBe(Some(3));expect(list.pop_back()).toBe(Some(1));
    });
});


