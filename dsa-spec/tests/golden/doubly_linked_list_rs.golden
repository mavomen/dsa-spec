// --- Node.rs ---
/// DoublyLinkedList
/// Time complexity: O(1) insert/remove at head/tail, O(n) search

/// Space complexity: O(n)

/// Invariants:
/// - no cycles
/// - for each node, node.next.prev == node

#[derive(Debug, Clone)]
pub struct Node<T>
where
    T: Clone,
{
    pub value: T,

    pub prev: Option<Box<Node<T>>>,

    pub next: Option<Box<Node<T>>>,
}

impl<T> Node<T> {
    pub fn new() -> Self {
        Self {
            value: Default::default(),

            prev: Default::default(),

            next: Default::default(),
        }
    }
}

// --- Node_new.rs ---
/// DoublyLinkedList.new

/// Returns: Self

/// Postconditions:
/// - head is None
/// - tail is None

impl<T> Node<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn push_front_pop_front() {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);
        list.push_front(2);
        assert_eq!(list.pop_front(), Some(2));
        assert_eq!(list.pop_front(), Some(1));
    }

    #[test]
    fn push_back_pop_back() {
        let mut list = DoublyLinkedList::new();
        list.push_back(1);
        list.push_back(2);
        assert_eq!(list.pop_back(), Some(2));
        assert_eq!(list.pop_back(), Some(1));
    }

    #[test]
    fn mixed_operations() {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);
        list.push_back(3);
        list.push_front(0);
        assert_eq!(list.pop_front(), Some(0));
        assert_eq!(list.pop_back(), Some(3));
        assert_eq!(list.pop_back(), Some(1));
    }
}

