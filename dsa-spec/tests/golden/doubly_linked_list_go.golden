// --- Node.go ---
// DoublyLinkedList
 // Time complexity: O(1) insert/remove at head/tail, O(n) search

 // Space complexity: O(n)


// Invariants:
 // - no cycles
 // - for each node, node.next.prev == node


package doublylinkedlist


type Node[T any] struct {

    
    Value T
    
    Prev *Node<T>
    
    Next *Node<T>
    
}

func NewNode[T any]() *Node[T] {
    return &Node[T]{}
}

// --- Node_new.go ---
// DoublyLinkedList.New

 // @returns Self



// Postconditions:
 // - head is None
 // - tail is None


package doublylinkedlist


func (s *Node[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestNodeNewpush_front_pop_front(t *testing.T) {
    let mut list = DoublyLinkedList::new();
    list.push_front(1)list.push_front(2)
    if list.pop_front() != Some(2) { t.Errorf("got %v, want %v", list.pop_front(), Some(2)) }if list.pop_front() != Some(1) { t.Errorf("got %v, want %v", list.pop_front(), Some(1)) }
}

func TestNodeNewpush_back_pop_back(t *testing.T) {
    let mut list = DoublyLinkedList::new();
    list.push_back(1)list.push_back(2)
    if list.pop_back() != Some(2) { t.Errorf("got %v, want %v", list.pop_back(), Some(2)) }if list.pop_back() != Some(1) { t.Errorf("got %v, want %v", list.pop_back(), Some(1)) }
}

func TestNodeNewmixed_operations(t *testing.T) {
    let mut list = DoublyLinkedList::new();
    list.push_front(1)list.push_back(3)list.push_front(0)
    if list.pop_front() != Some(0) { t.Errorf("got %v, want %v", list.pop_front(), Some(0)) }if list.pop_back() != Some(3) { t.Errorf("got %v, want %v", list.pop_back(), Some(3)) }if list.pop_back() != Some(1) { t.Errorf("got %v, want %v", list.pop_back(), Some(1)) }
}


