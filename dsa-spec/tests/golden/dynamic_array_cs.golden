/// <summary>
/// DynamicArray

/// Time complexity: O(1) amortized push, O(n) insert/remove


/// Space complexity: O(n)


/// Invariants:

/// - length >= 0

/// - capacity >= length


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace DynamicArray
{


