// ========== Generated xUnit tests ==========

public class push_increases_lengthTests
{
    [Fact]
    public void push_increases_length_Test()
    {
        // Setup
        let mut arr = DynamicArray::new();
        // Actions
        arr.push(1);arr.push(2);
        // Assertions
        Assert.AreEqual(arr.len(), 2);Assert.IsTrue(!arr.is_empty());
    }
}

public class pop_returns_last_elementTests
{
    [Fact]
    public void pop_returns_last_element_Test()
    {
        // Setup
        let mut arr = DynamicArray::new();
        // Actions
        arr.push(10);arr.push(20);
        // Assertions
        Assert.AreEqual(arr.pop(), Some(20));Assert.AreEqual(arr.len(), 1);
    }
}

public class pop_empty_returns_noneTests
{
    [Fact]
    public void pop_empty_returns_none_Test()
    {
        // Setup
        let arr = DynamicArray::<i32>::new();
        // Actions
        
        // Assertions
        Assert.AreEqual(arr.pop(), None);
    }
}

public class get_valid_indexTests
{
    [Fact]
    public void get_valid_index_Test()
    {
        // Setup
        let mut arr = DynamicArray::new(); arr.push(5);
        // Actions
        
        // Assertions
        Assert.AreEqual(arr.get(0), Some(&5));
    }
}

public class get_out_of_boundsTests
{
    [Fact]
    public void get_out_of_bounds_Test()
    {
        // Setup
        let mut arr = DynamicArray::new(); arr.push(5);
        // Actions
        
        // Assertions
        Assert.AreEqual(arr.get(1), None);
    }
}

}
