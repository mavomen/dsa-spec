// --- DynamicArray.Pop.cs ---
namespace DynamicArray
{
    public partial class DynamicArray<T>
    where T : Clone

    {
        /// <summary>
        /// Pop.
        /// </summary>
        
        
        /// <returns>T?.</returns>
        
        
        /// <remarks>
        /// Preconditions:
        
        /// - length > 0
        
        /// </remarks>
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - length == old.length - 1
        
        /// </remarks>
        
        
        public T? Pop()
        {
            
            throw new NotImplementedException();
        }
    }
}

