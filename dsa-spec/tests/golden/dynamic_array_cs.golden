// --- DynamicArray.cs ---
/// <summary>
/// DynamicArray

/// Time complexity: O(1) amortized push, O(n) insert/remove


/// Space complexity: O(n)


/// Invariants:

/// - length >= 0

/// - capacity >= length


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace DynamicArray
{
    public partial class DynamicArray<T>
    where T : Clone

    {
        
        public List<T> Data { get; set; }
        
        public int Len { get; set; }
        
    }
}

// --- DynamicArray.New.cs ---
namespace DynamicArray
{
    public partial class DynamicArray<T>
    where T : Clone

    {
        /// <summary>
        /// New.
        /// </summary>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - length == 0
        
        /// - capacity >= 0
        
        /// </remarks>
        
        
        public Self New()
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class DynamicArraypush_increases_lengthTests
{
    [Fact]
    public void push_increases_length_Test()
    {
        let mut arr = DynamicArray::new();
        arr.push(1);arr.push(2);
        Assert.AreEqual(arr.len(), 2);Assert.IsTrue(!arr.is_empty());
    }
}

public class DynamicArraypop_returns_last_elementTests
{
    [Fact]
    public void pop_returns_last_element_Test()
    {
        let mut arr = DynamicArray::new();
        arr.push(10);arr.push(20);
        Assert.AreEqual(arr.pop(), Some(20));Assert.AreEqual(arr.len(), 1);
    }
}

public class DynamicArraypop_empty_returns_noneTests
{
    [Fact]
    public void pop_empty_returns_none_Test()
    {
        let arr = DynamicArray::<i32>::new();
        
        Assert.AreEqual(arr.pop(), None);
    }
}

public class DynamicArrayget_valid_indexTests
{
    [Fact]
    public void get_valid_index_Test()
    {
        let mut arr = DynamicArray::new(); arr.push(5);
        
        Assert.AreEqual(arr.get(0), Some(&5));
    }
}

public class DynamicArrayget_out_of_boundsTests
{
    [Fact]
    public void get_out_of_bounds_Test()
    {
        let mut arr = DynamicArray::new(); arr.push(5);
        
        Assert.AreEqual(arr.get(1), None);
    }
}


// --- DynamicArray.Push.cs ---
namespace DynamicArray
{
    public partial class DynamicArray<T>
    where T : Clone

    {
        /// <summary>
        /// Push.
        /// </summary>
        
        /// <param name="item">T.</param>
        
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - length == old.length + 1
        
        /// - last element == item
        
        /// </remarks>
        
        
        public void Push(T item)
        {
            
            throw new NotImplementedException();
        }
    }
}

