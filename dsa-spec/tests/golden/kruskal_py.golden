# ========== Generated pytest tests ==========

def test_simple_graph_mst():
    """Test: simple_graph_mst"""
    let vertices = 4;
    let edges = vec![(0, 1, 10), (0, 2, 6), (0, 3, 5), (1, 3, 15), (2, 3, 4)]let mst = kruskal(vertices, edges)
    assert mst.len() == 3assert total_weight(&mst) == 19

def test_single_vertex():
    """Test: single_vertex"""
    let vertices = 1;
    let edges: Vec<(usize, usize, usize)> = vec![]let mst = kruskal(vertices, edges)
    assert mst.len() == 0

def test_disconnected_graph():
    """Test: disconnected_graph"""
    let vertices = 3;
    let edges = vec![(0, 1, 5)]let mst = kruskal(vertices, edges)
    assert mst.len() == 1


if __name__ == "__main__":
