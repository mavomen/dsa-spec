// --- MaxHeap.go ---
// MaxHeap
// Time complexity: O(log n) insert/extract, O(1) peek

// Space complexity: O(n)

// Invariants:
// - parent value >= children values
// - tree is complete (all levels filled left-to-right)
// - size == data.len()

package maxheap

type MaxHeap[T constraints.Ordered] struct {
	Data []T
}

func NewMaxHeap[T constraints.Ordered]() *MaxHeap[T] {
	return &MaxHeap[T]{}
}

// --- MaxHeap_new.go ---
// MaxHeap.New

 // @returns Self



// Postconditions:
 // - is_empty() == true
 // - size() == 0


package maxheap


func (s *MaxHeap[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestMaxHeapNewinsert_and_extract_max(t *testing.T) {
    let mut heap = MaxHeap::new();
    heap.insert(3)heap.insert(5)heap.insert(1)heap.insert(4)
    if heap.extract_max() != Some(5) { t.Errorf("got %v, want %v", heap.extract_max(), Some(5)) }if heap.extract_max() != Some(4) { t.Errorf("got %v, want %v", heap.extract_max(), Some(4)) }if heap.extract_max() != Some(3) { t.Errorf("got %v, want %v", heap.extract_max(), Some(3)) }if heap.extract_max() != Some(1) { t.Errorf("got %v, want %v", heap.extract_max(), Some(1)) }if heap.extract_max() != None { t.Errorf("got %v, want %v", heap.extract_max(), None) }
}

func TestMaxHeapNewpeek_returns_largest(t *testing.T) {
    let mut heap = MaxHeap::new();
    heap.insert(10)heap.insert(20)
    if *heap.peek().unwrap() != 20 { t.Errorf("got %v, want %v", *heap.peek().unwrap(), 20) }
}

func TestMaxHeapNewempty_heap_returns_none(t *testing.T) {
    let heap: MaxHeap<i32> = MaxHeap::new();
    
    if !(heap.peek().is_none()) { t.Errorf("assertion failed: heap.peek().is_none()") }if !(heap.extract_max().is_none()) { t.Errorf("assertion failed: heap.extract_max().is_none()") }if !(heap.is_empty()) { t.Errorf("assertion failed: heap.is_empty()") }
}

func TestMaxHeapNewsize_tracks_insertions(t *testing.T) {
    let mut heap = MaxHeap::new();
    heap.insert(1)heap.insert(2)heap.insert(3)
    if heap.size() != 3 { t.Errorf("got %v, want %v", heap.size(), 3) }heap.extract_max()if heap.size() != 2 { t.Errorf("got %v, want %v", heap.size(), 2) }
}


