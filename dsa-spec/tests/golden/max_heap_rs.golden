        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn insert_and_extract_max() {
        let mut heap = MaxHeap::new();
        heap.insert(3);
        heap.insert(5);
        heap.insert(1);
        heap.insert(4);
        assert_eq!(heap.extract_max(), Some(5));
        assert_eq!(heap.extract_max(), Some(4));
        assert_eq!(heap.extract_max(), Some(3));
        assert_eq!(heap.extract_max(), Some(1));
        assert_eq!(heap.extract_max(), None);
    }

    #[test]
    fn peek_returns_largest() {
        let mut heap = MaxHeap::new();
        heap.insert(10);
        heap.insert(20);
        assert_eq!(*heap.peek().unwrap(), 20);
    }

    #[test]
    fn empty_heap_returns_none() {
        let heap: MaxHeap<i32> = MaxHeap::new();

        assert!(heap.peek().is_none());
        assert!(heap.extract_max().is_none());
        assert!(heap.is_empty());
    }

    #[test]
    fn size_tracks_insertions() {
        let mut heap = MaxHeap::new();
        heap.insert(1);
        heap.insert(2);
        heap.insert(3);
        assert_eq!(heap.size(), 3);
        heap.extract_max();
        assert_eq!(heap.size(), 2);
    }
}

