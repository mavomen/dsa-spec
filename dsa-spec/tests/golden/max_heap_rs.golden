// --- MaxHeap.rs ---
/// MaxHeap
/// Time complexity: O(log n) insert/extract, O(1) peek

/// Space complexity: O(n)


/// Invariants:
/// - parent value >= children values
/// - tree is complete (all levels filled left-to-right)
/// - size == data.len()



#[derive(Debug, Clone)]
pub struct MaxHeap<T>
where T: Ord + Clone 

    
    pub data: Vec<T>,
    
}

impl<T> MaxHeap<T> {
    pub fn new() -> Self {
        Self {
            
            data: Vec::new(),
            
        }
    }
}

// --- MaxHeap_new.rs ---
/// MaxHeap.new

/// Returns: Self

/// Postconditions:
/// - is_empty() == true
/// - size() == 0

impl<T> MaxHeap<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn insert_and_extract_max() {
        let mut heap = MaxHeap::new();
        heap.insert(3);
        heap.insert(5);
        heap.insert(1);
        heap.insert(4);
        assert_eq!(heap.extract_max(), Some(5));
        assert_eq!(heap.extract_max(), Some(4));
        assert_eq!(heap.extract_max(), Some(3));
        assert_eq!(heap.extract_max(), Some(1));
        assert_eq!(heap.extract_max(), None);
    }

    #[test]
    fn peek_returns_largest() {
        let mut heap = MaxHeap::new();
        heap.insert(10);
        heap.insert(20);
        assert_eq!(*heap.peek().unwrap(), 20);
    }

    #[test]
    fn empty_heap_returns_none() {
        let heap: MaxHeap<i32> = MaxHeap::new();

        assert!(heap.peek().is_none());
        assert!(heap.extract_max().is_none());
        assert!(heap.is_empty());
    }

    #[test]
    fn size_tracks_insertions() {
        let mut heap = MaxHeap::new();
        heap.insert(1);
        heap.insert(2);
        heap.insert(3);
        assert_eq!(heap.size(), 3);
        heap.extract_max();
        assert_eq!(heap.size(), 2);
    }
}

// --- MaxHeap_insert.rs ---
/// MaxHeap.insert
/// * `value` - T

/// Postconditions:
/// - size() == old.size() + 1
/// - heap invariant maintained

impl<T> MaxHeap<T> {
