# ========== Generated pytest tests ==========

def test_bfs_level_order():
    """Test: bfs_level_order"""
    let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_vertex(4);
g.add_edge(1, 2);
g.add_edge(1, 3);
g.add_edge(2, 4);

    
    let order = bfs(&g, 1);assert order[0] == 1assert order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2assert order[3] == 4

def test_bfs_disconnected():
    """Test: bfs_disconnected"""
    let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

    
    assert bfs(&g, 1) == vec![1]

def test_bfs_single_node():
    """Test: bfs_single_node"""
    let mut g = Graph::new(false);
g.add_vertex(42);

    
    assert bfs(&g, 42) == vec![42]


