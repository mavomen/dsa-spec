// --- BSTNode.ts ---
/**
 * BinarySearchTree
 * Time complexity: O(log n) average, O(n) worst

 * Space complexity: O(n)


 * Invariants:
 * - left.value < node.value < right.value
 * - no duplicate values

 */


export class BSTNode<T> {

    
    public value: T;
    
    public left: BSTNode<T> | null;
    
    public right: BSTNode<T> | null;
    
}

// --- BSTNode_new.ts ---
/**
 * BinarySearchTree.new

 * @returns Self



 * Postconditions:
 * - root is None

 */

import { BSTNode } from './bstnode';


(BSTNode.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('insert_and_contains', () => {
    it('should pass', () => {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);bst.insert(3);bst.insert(7);
        expect(bst.contains(5)).toBe(true);expect(bst.contains(3)).toBe(true);expect(bst.contains(7)).toBe(true);expect(!bst.contains(10)).toBe(true);
    });
});

describe('inorder_returns_sorted', () => {
    it('should pass', () => {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);bst.insert(3);bst.insert(7);bst.insert(1);bst.insert(9);
        expect(bst.inorder()).toBe(vec![1, 3, 5, 7, 9]);
    });
});

describe('duplicate_insert_returns_false', () => {
    it('should pass', () => {
        let mut bst = BinarySearchTree::new();
        bst.insert(10);
        expect(bst.insert(10)).toBe(false);
    });
});


