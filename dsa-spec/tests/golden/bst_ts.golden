// ========== Generated Jest tests ==========

describe('insert_and_contains', () => {
    it('should work', () => {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(5);bst.insert(3);bst.insert(7);
        // Assertions
        expect(bst.contains(5)).toBe(true);expect(bst.contains(3)).toBe(true);expect(bst.contains(7)).toBe(true);expect(!bst.contains(10)).toBe(true);
    });
});

describe('inorder_returns_sorted', () => {
    it('should work', () => {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(5);bst.insert(3);bst.insert(7);bst.insert(1);bst.insert(9);
        // Assertions
        expect(bst.inorder()).toBe(vec![1, 3, 5, 7, 9]);
    });
});

describe('duplicate_insert_returns_false', () => {
    it('should work', () => {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(10);
        // Assertions
        expect(bst.insert(10)).toBe(false);
    });
});

