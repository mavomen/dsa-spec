// --- Stack.rs ---
/// Stack
/// Time complexity: O(1) push/pop, O(n) search

/// Space complexity: O(n)


/// Invariants:
/// - length >= 0



#[derive(Debug, Clone)]
pub struct Stack<T>
where T: Clone 

    
    pub items: Vec<T>,
    
}

impl<T> Stack<T> {
    pub fn new() -> Self {
        Self {
            
            items: Vec::new(),
            
        }
    }
}

// --- Stack_new.rs ---
/// Stack.new

/// Returns: Self

/// Postconditions:
/// - length == 0

impl<T> Stack<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn push_and_pop() {
        let mut s = Stack::new();
        s.push(1);
        s.push(2);
        assert_eq!(s.pop(), Some(2));
        assert_eq!(s.pop(), Some(1));
        assert!(s.is_empty());
    }

    #[test]
    fn peek_returns_top() {
        let mut s = Stack::new();
        s.push(42);
        assert_eq!(s.peek(), Some(&42));
    }

    #[test]
    fn pop_empty_returns_none() {
        let mut s = Stack::<i32>::new();

        assert_eq!(s.pop(), None);
    }

    #[test]
    fn len_tracks_elements() {
        let mut s = Stack::new();
        s.push(10);
        s.push(20);
        assert_eq!(s.len(), 2);
    }
}

