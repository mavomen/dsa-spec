// --- BSTNode.go ---
// BinarySearchTree
 // Time complexity: O(log n) average, O(n) worst

 // Space complexity: O(n)


// Invariants:
 // - left.value < node.value < right.value
 // - no duplicate values


package binarysearchtree


type BSTNode[T constraints.Ordered] struct {

    
    Value T
    
    Left *BSTNode<T>
    
    Right *BSTNode<T>
    
}

func NewBSTNode[T constraints.Ordered]() *BSTNode[T] {
    return &BSTNode[T]{}
}

// --- BSTNode_new.go ---
// BinarySearchTree.New

 // @returns Self



// Postconditions:
 // - root is None


package binarysearchtree


func (s *BSTNode[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestBSTNodeNewinsert_and_contains(t *testing.T) {
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)
    if !(bst.contains(5)) { t.Errorf("assertion failed: bst.contains(5)") }if !(bst.contains(3)) { t.Errorf("assertion failed: bst.contains(3)") }if !(bst.contains(7)) { t.Errorf("assertion failed: bst.contains(7)") }if !(!bst.contains(10)) { t.Errorf("assertion failed: !bst.contains(10)") }
}

func TestBSTNodeNewinorder_returns_sorted(t *testing.T) {
    let mut bst = BinarySearchTree::new();
    bst.insert(5)bst.insert(3)bst.insert(7)bst.insert(1)bst.insert(9)
    if bst.inorder() != vec![1, 3, 5, 7, 9] { t.Errorf("got %v, want %v", bst.inorder(), vec![1, 3, 5, 7, 9]) }
}

func TestBSTNodeNewduplicate_insert_returns_false(t *testing.T) {
    let mut bst = BinarySearchTree::new();
    bst.insert(10)
    if bst.insert(10) != false { t.Errorf("got %v, want %v", bst.insert(10), false) }
}


