// --- BinarySearchMethods.rs ---
/// BinarySearch

/// Time complexity: O(log n)

/// Space complexity: O(1)

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_find_element_in_middle() {
        let arr = vec![1, 3, 5, 7, 9];
        let result = binary_search(&arr, &5);
        assert_eq!(result, Some(2));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_find_first_element() {
        let arr = vec![1, 3, 5, 7, 9];
        let result = binary_search(&arr, &1);
        assert_eq!(result, Some(0));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_find_last_element() {
        let arr = vec![1, 3, 5, 7, 9];
        let result = binary_search(&arr, &9);
        assert_eq!(result, Some(4));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_element_not_found() {
        let arr = vec![1, 3, 5, 7, 9];
        let result = binary_search(&arr, &4);
        assert_eq!(result, None);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_empty_array() {
        let arr: Vec<i32> = vec![];
        let result = binary_search(&arr, &1);
        assert_eq!(result, None);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_single_element_found() {
        let arr = vec![42];
        let result = binary_search(&arr, &42);
        assert_eq!(result, Some(0));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_single_element_not_found() {
        let arr = vec![42];
        let result = binary_search(&arr, &1);
        assert_eq!(result, None);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_duplicate_elements() {
        let arr = vec![1, 2, 2, 2, 3];
        let result = binary_search(&arr, &2);
        assert!(result.is_some());
        let idx = result.unwrap();
        assert!(idx >= 1 && idx <= 3);
    }
}
