// --- CircularBuffer.cs ---
/// <summary>
/// CircularBuffer

/// Time complexity: O(1) enqueue/dequeue


/// Space complexity: O(n)


/// Invariants:

/// - length <= capacity

/// - 0 <= head < capacity

/// - 0 <= tail < capacity


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace CircularBuffer
{
    public partial class CircularBuffer<T>
    where T : Clone, Default

    {
        
        public List<T?> Buffer { get; set; }
        
        public int Head { get; set; }
        
        public int Tail { get; set; }
        
        public int Size { get; set; }
        
        public int Capacity { get; set; }
        
    }
}

// --- CircularBuffer.New.cs ---
namespace CircularBuffer
{
    public partial class CircularBuffer<T>
    where T : Clone, Default

    {
        /// <summary>
        /// New.
        /// </summary>
        
        /// <param name="capacity">int.</param>
        
        
        /// <returns>Self.</returns>
        
        
        /// <remarks>
        /// Preconditions:
        
        /// - capacity > 0
        
        /// </remarks>
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - is_empty() == true
        
        /// - capacity == capacity
        
        /// </remarks>
        
        
        public Self New(int capacity)
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class CircularBufferenqueue_dequeue_fifoTests
{
    [Fact]
    public void enqueue_dequeue_fifo_Test()
    {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);
        Assert.AreEqual(buf.dequeue(), Some(1));Assert.AreEqual(buf.dequeue(), Some(2));
    }
}

public class CircularBufferfull_buffer_prevents_enqueueTests
{
    [Fact]
    public void full_buffer_prevents_enqueue_Test()
    {
        let mut buf = CircularBuffer::new(1);
        buf.enqueue(42);
        Assert.IsTrue(buf.is_full());Assert.IsTrue(buf.enqueue(43).is_err());
    }
}

public class CircularBufferempty_buffer_returns_noneTests
{
    [Fact]
    public void empty_buffer_returns_none_Test()
    {
        let buf = CircularBuffer::<i32>::new(5);
        
        Assert.AreEqual(buf.dequeue(), None);
    }
}

public class CircularBufferwrap_around_worksTests
{
    [Fact]
    public void wrap_around_works_Test()
    {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);buf.dequeue();buf.enqueue(3);buf.enqueue(4);
        Assert.AreEqual(buf.dequeue(), Some(2));Assert.AreEqual(buf.dequeue(), Some(3));Assert.AreEqual(buf.dequeue(), Some(4));
    }
}


// --- CircularBuffer.Enqueue.cs ---
namespace CircularBuffer
{
    public partial class CircularBuffer<T>
    where T : Clone, Default

    {
        /// <summary>
        /// Enqueue.
        /// </summary>
        
        /// <param name="item">T.</param>
        
        
        /// <returns>().</returns>
        
        
        /// <remarks>
        /// Preconditions:
        
        /// - size < capacity
        
        /// </remarks>
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - size == old.size + 1
        
        /// </remarks>
        
        
        /// <exception cref="Exception">Thrown when an error occurs (from Result type).</exception>
        
        public () Enqueue(T item)
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class CircularBufferenqueue_dequeue_fifoTests
{
    [Fact]
    public void enqueue_dequeue_fifo_Test()
    {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);
        Assert.AreEqual(buf.dequeue(), Some(1));Assert.AreEqual(buf.dequeue(), Some(2));
    }
}

public class CircularBufferfull_buffer_prevents_enqueueTests
{
    [Fact]
    public void full_buffer_prevents_enqueue_Test()
    {
        let mut buf = CircularBuffer::new(1);
        buf.enqueue(42);
        Assert.IsTrue(buf.is_full());Assert.IsTrue(buf.enqueue(43).is_err());
    }
}

public class CircularBufferempty_buffer_returns_noneTests
{
    [Fact]
    public void empty_buffer_returns_none_Test()
    {
        let buf = CircularBuffer::<i32>::new(5);
        
        Assert.AreEqual(buf.dequeue(), None);
    }
}

public class CircularBufferwrap_around_worksTests
{
    [Fact]
    public void wrap_around_works_Test()
    {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);buf.enqueue(2);buf.dequeue();buf.enqueue(3);buf.enqueue(4);
        Assert.AreEqual(buf.dequeue(), Some(2));Assert.AreEqual(buf.dequeue(), Some(3));Assert.AreEqual(buf.dequeue(), Some(4));
    }
}


