/// <summary>
/// CircularBuffer

/// Time complexity: O(1) enqueue/dequeue


/// Space complexity: O(n)


/// Invariants:

/// - length <= capacity

/// - 0 <= head < capacity

/// - 0 <= tail < capacity


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace CircularBuffer
{


