// ========== Generated tests ==========

func Testdfs_simple_path(t *testing.T) {
	let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);

	
	if dfs(&g, 1) != vec![1, 2, 3] { t.Errorf("got %v, want %v", dfs(&g, 1), vec![1, 2, 3]) }
}

func Testdfs_disconnected(t *testing.T) {
	let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

	
	if dfs(&g, 1) != vec![1] { t.Errorf("got %v, want %v", dfs(&g, 1), vec![1]) }
}

func Testdfs_cyclic_graph(t *testing.T) {
	let mut g = Graph::new(true);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);
g.add_edge(3, 1);

	
	if dfs(&g, 1).len() != 3 { t.Errorf("got %v, want %v", dfs(&g, 1).len(), 3) }
}

