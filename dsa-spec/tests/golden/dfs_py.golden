# ========== Generated pytest tests ==========

def test_dfs_simple_path():
    """Test: dfs_simple_path"""
    let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);

    
    assert dfs(&g, 1) == vec![1, 2, 3]

def test_dfs_disconnected():
    """Test: dfs_disconnected"""
    let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

    
    assert dfs(&g, 1) == vec![1]

def test_dfs_cyclic_graph():
    """Test: dfs_cyclic_graph"""
    let mut g = Graph::new(true);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);
g.add_edge(3, 1);

    
    assert dfs(&g, 1).len() == 3


if __name__ == "__main__":
    pytest.main([__file__])
