// --- Graph.go ---
// Graph
 // Time complexity: O(V+E) for traversal

 // Space complexity: O(V+E)


// Invariants:
 // - all edges reference valid vertices
 // - vertex count >= 0


package graph


type Graph[T comparable] struct {

    
    AdjacencyList HashMap<T, Vec<T>>
    
    Directed bool
    
}

func NewGraph[T comparable]() *Graph[T] {
    return &Graph[T]{}
}

// --- Graph_new.go ---
// Graph.New
 // @param directed - bool

 // @returns Self



// Postconditions:
 // - vertex_count == 0
 // - edge_count == 0


package graph


func (s *Graph[T]) New(directed bool) Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestGraphNewadd_vertex_and_edge(t *testing.T) {
    let mut g = Graph::new(false);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    if !(g.has_vertex(1)) { t.Errorf("assertion failed: g.has_vertex(1)") }if !(g.has_vertex(2)) { t.Errorf("assertion failed: g.has_vertex(2)") }if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if g.vertex_count() != 2 { t.Errorf("got %v, want %v", g.vertex_count(), 2) }if g.edge_count() != 1 { t.Errorf("got %v, want %v", g.edge_count(), 1) }
}

func TestGraphNewundirected_graph_symmetric_edges(t *testing.T) {
    let mut g = Graph::new(false);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if !(g.has_edge(2, 1)) { t.Errorf("assertion failed: g.has_edge(2, 1)") }
}

func TestGraphNewdirected_graph_no_symmetry(t *testing.T) {
    let mut g = Graph::new(true);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if !(!g.has_edge(2, 1)) { t.Errorf("assertion failed: !g.has_edge(2, 1)") }
}


