// GraphInterface defines the contract for Graph
type GraphInterface[T any] interface {

	
	New(directed bool) Self
	
	AddVertex(vertex T) bool
	
	AddEdge(from T, to T) bool
	
	Neighbors(vertex T) *&Vec<T>
	
	VertexCount() int
	
	EdgeCount() int
	
	HasVertex(vertex T) bool
	
	HasEdge(from T, to T) bool
	
}


// Graph represents a Graph
