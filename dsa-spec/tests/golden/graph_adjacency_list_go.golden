// ========== Generated tests ==========

func Testadd_vertex_and_edge(t *testing.T) {
	let mut g = Graph::new(false);
	g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
	if !(g.has_vertex(1)) { t.Errorf("assertion failed: g.has_vertex(1)") }if !(g.has_vertex(2)) { t.Errorf("assertion failed: g.has_vertex(2)") }if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if g.vertex_count() != 2 { t.Errorf("got %v, want %v", g.vertex_count(), 2) }if g.edge_count() != 1 { t.Errorf("got %v, want %v", g.edge_count(), 1) }
}

func Testundirected_graph_symmetric_edges(t *testing.T) {
	let mut g = Graph::new(false);
	g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
	if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if !(g.has_edge(2, 1)) { t.Errorf("assertion failed: g.has_edge(2, 1)") }
}

func Testdirected_graph_no_symmetry(t *testing.T) {
	let mut g = Graph::new(true);
	g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
	if !(g.has_edge(1, 2)) { t.Errorf("assertion failed: g.has_edge(1, 2)") }if !(!g.has_edge(2, 1)) { t.Errorf("assertion failed: !g.has_edge(2, 1)") }
}

