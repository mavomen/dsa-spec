// --- DynamicArray_pop.py ---
"""
DynamicArray.pop

Preconditions:
    - length > 0


Postconditions:
    - length == old.length - 1

"""

from dynamicarray import DynamicArray


def pop(self, ) -> Optional[T]:
    """pop."""
    
    raise NotImplementedError


DynamicArray.pop = pop

del pop


