// --- DynamicArray.py ---
"""
DynamicArray
Time complexity: O(1) amortized push, O(n) insert/remove
Space complexity: O(n)

Invariants:
    - length >= 0
    - capacity >= length

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict

T = TypeVar("T")


@dataclass
class DynamicArray(Generic[T]):
    """DynamicArray"""

    data: List[T]

    len: int

// --- DynamicArray_new.py ---
"""
DynamicArray.new


Postconditions:
    - length == 0
    - capacity >= 0

"""

from dynamicarray import DynamicArray


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


DynamicArray.new = new

del new


# ========== Generated tests ==========

def test_push_increases_length():
    let mut arr = DynamicArray::new();
    arr.push(1)arr.push(2)
    assert arr.len() == 2assert !arr.is_empty()

def test_pop_returns_last_element():
    let mut arr = DynamicArray::new();
    arr.push(10)arr.push(20)
    assert arr.pop() == Some(20)assert arr.len() == 1

def test_pop_empty_returns_none():
    let arr = DynamicArray::<i32>::new();
    
    assert arr.pop() == None

def test_get_valid_index():
    let mut arr = DynamicArray::new(); arr.push(5);
    
    assert arr.get(0) == Some(&5)

def test_get_out_of_bounds():
    let mut arr = DynamicArray::new(); arr.push(5);
    
    assert arr.get(1) == None


// --- DynamicArray_push.py ---
"""
DynamicArray.push


Postconditions:
    - length == old.length + 1
    - last element == item

"""

from dynamicarray import DynamicArray


def push(self, item: T) -> None:
    """push."""
    
    raise NotImplementedError


DynamicArray.push = push

del push


