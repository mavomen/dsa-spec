// --- Node.go ---
// SinglyLinkedList
 // Time complexity: O(1) prepend, O(n) append/search

 // Space complexity: O(n)


// Invariants:
 // - no cycles
 // - head is None iff tail is None


package singlylinkedlist


type Node[T any] struct {

    
    Value T
    
    Next *Node<T>
    
}

func NewNode[T any]() *Node[T] {
    return &Node[T]{}
}

// --- Node_new.go ---
// SinglyLinkedList.New

 // @returns Self



// Postconditions:
 // - head is None


package singlylinkedlist


func (s *Node[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestNodeNewprepend_pop_front(t *testing.T) {
    let mut list = SinglyLinkedList::new();
    list.prepend(1)list.prepend(2)
    if list.pop_front() != Some(2) { t.Errorf("got %v, want %v", list.pop_front(), Some(2)) }if list.pop_front() != Some(1) { t.Errorf("got %v, want %v", list.pop_front(), Some(1)) }
}

func TestNodeNewappend_order(t *testing.T) {
    let mut list = SinglyLinkedList::new();
    list.append(1)list.append(2)
    if list.pop_front() != Some(1) { t.Errorf("got %v, want %v", list.pop_front(), Some(1)) }
}

func TestNodeNewpop_front_empty(t *testing.T) {
    let list = SinglyLinkedList::<i32>::new();
    
    if list.pop_front() != None { t.Errorf("got %v, want %v", list.pop_front(), None) }
}


