// ========== Generated tests ==========

func Testprepend_pop_front(t *testing.T) {
	let mut list = SinglyLinkedList::new();
	list.prepend(1)list.prepend(2)
	if list.pop_front() != Some(2) { t.Errorf("got %v, want %v", list.pop_front(), Some(2)) }if list.pop_front() != Some(1) { t.Errorf("got %v, want %v", list.pop_front(), Some(1)) }
}

func Testappend_order(t *testing.T) {
	let mut list = SinglyLinkedList::new();
	list.append(1)list.append(2)
	if list.pop_front() != Some(1) { t.Errorf("got %v, want %v", list.pop_front(), Some(1)) }
}

func Testpop_front_empty(t *testing.T) {
	let list = SinglyLinkedList::<i32>::new();
	
	if list.pop_front() != None { t.Errorf("got %v, want %v", list.pop_front(), None) }
}

