// ========== Generated xUnit tests ==========

public class dfs_simple_pathTests
{
    [Fact]
    public void dfs_simple_path_Test()
    {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);

        // Actions
        
        // Assertions
        Assert.AreEqual(dfs(&g, 1), vec![1, 2, 3]);
    }
}

public class dfs_disconnectedTests
{
    [Fact]
    public void dfs_disconnected_Test()
    {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

        // Actions
        
        // Assertions
        Assert.AreEqual(dfs(&g, 1), vec![1]);
    }
}

public class dfs_cyclic_graphTests
{
    [Fact]
    public void dfs_cyclic_graph_Test()
    {
        // Setup
        let mut g = Graph::new(true);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);
g.add_edge(3, 1);

        // Actions
        
        // Assertions
        Assert.AreEqual(dfs(&g, 1).len(), 3);
    }
}

