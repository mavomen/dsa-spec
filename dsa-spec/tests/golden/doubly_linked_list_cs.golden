// ========== Generated xUnit tests ==========

public class push_front_pop_frontTests
{
    [Fact]
    public void push_front_pop_front_Test()
    {
        // Setup
        let mut list = DoublyLinkedList::new();
        // Actions
        list.push_front(1);list.push_front(2);
        // Assertions
        Assert.AreEqual(list.pop_front(), Some(2));Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class push_back_pop_backTests
{
    [Fact]
    public void push_back_pop_back_Test()
    {
        // Setup
        let mut list = DoublyLinkedList::new();
        // Actions
        list.push_back(1);list.push_back(2);
        // Assertions
        Assert.AreEqual(list.pop_back(), Some(2));Assert.AreEqual(list.pop_back(), Some(1));
    }
}

public class mixed_operationsTests
{
    [Fact]
    public void mixed_operations_Test()
    {
        // Setup
        let mut list = DoublyLinkedList::new();
        // Actions
        list.push_front(1);list.push_back(3);list.push_front(0);
        // Assertions
        Assert.AreEqual(list.pop_front(), Some(0));Assert.AreEqual(list.pop_back(), Some(3));Assert.AreEqual(list.pop_back(), Some(1));
    }
}

}
