// --- Node.cs ---
/// <summary>
/// DoublyLinkedList

/// Time complexity: O(1) insert/remove at head/tail, O(n) search


/// Space complexity: O(n)


/// Invariants:

/// - no cycles

/// - for each node, node.next.prev == node


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace DoublyLinkedList
{
    public partial class Node<T>
    where T : Clone

    {
        
        public T Value { get; set; }
        
        public Node<T>? Prev { get; set; }
        
        public Node<T>? Next { get; set; }
        
    }
}

// --- Node.New.cs ---
namespace DoublyLinkedList
{
    public partial class Node<T>
    where T : Clone

    {
        /// <summary>
        /// New.
        /// </summary>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - head is None
        
        /// - tail is None
        
        /// </remarks>
        
        
        public Self New()
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class Nodepush_front_pop_frontTests
{
    [Fact]
    public void push_front_pop_front_Test()
    {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);list.push_front(2);
        Assert.AreEqual(list.pop_front(), Some(2));Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class Nodepush_back_pop_backTests
{
    [Fact]
    public void push_back_pop_back_Test()
    {
        let mut list = DoublyLinkedList::new();
        list.push_back(1);list.push_back(2);
        Assert.AreEqual(list.pop_back(), Some(2));Assert.AreEqual(list.pop_back(), Some(1));
    }
}

public class Nodemixed_operationsTests
{
    [Fact]
    public void mixed_operations_Test()
    {
        let mut list = DoublyLinkedList::new();
        list.push_front(1);list.push_back(3);list.push_front(0);
        Assert.AreEqual(list.pop_front(), Some(0));Assert.AreEqual(list.pop_back(), Some(3));Assert.AreEqual(list.pop_back(), Some(1));
    }
}


