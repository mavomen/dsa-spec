# ========== Generated pytest tests ==========

def test_find_element_in_middle():
    """Test: find_element_in_middle"""
    let arr = vec![1, 3, 5, 7, 9];
    let result = binary_search(&arr, &5)
    assert result == Some(2)

def test_find_first_element():
    """Test: find_first_element"""
    let arr = vec![1, 3, 5, 7, 9];
    let result = binary_search(&arr, &1)
    assert result == Some(0)

def test_find_last_element():
    """Test: find_last_element"""
    let arr = vec![1, 3, 5, 7, 9];
    let result = binary_search(&arr, &9)
    assert result == Some(4)

def test_element_not_found():
    """Test: element_not_found"""
    let arr = vec![1, 3, 5, 7, 9];
    let result = binary_search(&arr, &4)
    assert result == None

def test_empty_array():
    """Test: empty_array"""
    let arr: Vec<i32> = vec![];
    let result = binary_search(&arr, &1)
    assert result == None

def test_single_element_found():
    """Test: single_element_found"""
    let arr = vec![42];
    let result = binary_search(&arr, &42)
    assert result == Some(0)

def test_single_element_not_found():
    """Test: single_element_not_found"""
    let arr = vec![42];
    let result = binary_search(&arr, &1)
    assert result == None

def test_duplicate_elements():
    """Test: duplicate_elements"""
    let arr = vec![1, 2, 2, 2, 3];
    let result = binary_search(&arr, &2)
    assert result.is_some()let idx = result.unwrap();assert idx >= 1 && idx <= 3


if __name__ == "__main__":
    pytest.main([__file__])
