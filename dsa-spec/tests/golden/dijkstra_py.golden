# ========== Generated pytest tests ==========

def test_simple_path():
    """Test: simple_path"""
    let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
    graph.insert(0, vec![(1, 4), (2, 1)])graph.insert(1, vec![(3, 1)])graph.insert(2, vec![(1, 2), (3, 5)])graph.insert(3, vec![])let dist = dijkstra(&graph, 0)
    assert dist[&0] == 0assert dist[&1] == 3assert dist[&2] == 1assert dist[&3] == 4

def test_unreachable_vertex():
    """Test: unreachable_vertex"""
    let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
    graph.insert(0, vec![(1, 1)])graph.insert(1, vec![])graph.insert(2, vec![])let dist = dijkstra(&graph, 0)
    assert dist[&0] == 0assert dist[&1] == 1assert !dist.contains_key(&2)


if __name__ == "__main__":
    pytest.main([__file__])
