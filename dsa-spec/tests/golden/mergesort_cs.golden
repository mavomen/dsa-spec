// ========== Generated xUnit tests ==========

public class sort_unsorted_arrayTests
{
    [Fact]
    public void sort_unsorted_array_Test()
    {
        // Setup
        let mut arr = vec![5, 3, 8, 1, 2];
        // Actions
        mergesort(&mut arr);
        // Assertions
        Assert.AreEqual(arr, vec![1, 2, 3, 5, 8]);
    }
}

public class sort_empty_arrayTests
{
    [Fact]
    public void sort_empty_array_Test()
    {
        // Setup
        let mut arr: Vec<i32> = vec![];
        // Actions
        mergesort(&mut arr);
        // Assertions
        Assert.AreEqual(arr, vec![]);
    }
}

public class sort_single_elementTests
{
    [Fact]
    public void sort_single_element_Test()
    {
        // Setup
        let mut arr = vec![7];
        // Actions
        mergesort(&mut arr);
        // Assertions
        Assert.AreEqual(arr, vec![7]);
    }
}

public class sort_already_sortedTests
{
    [Fact]
    public void sort_already_sorted_Test()
    {
        // Setup
        let mut arr = vec![1, 2, 3, 4, 5];
        // Actions
        mergesort(&mut arr);
        // Assertions
        Assert.AreEqual(arr, vec![1, 2, 3, 4, 5]);
    }
}

