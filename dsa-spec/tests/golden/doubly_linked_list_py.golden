// --- Node.py ---
"""
DoublyLinkedList
Time complexity: O(1) insert/remove at head/tail, O(n) search
Space complexity: O(n)

Invariants:
    - no cycles
    - for each node, node.next.prev == node

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict


T = TypeVar('T')



@dataclass
class Node(Generic[T]):
    """DoublyLinkedList"""
    
    value: T
    
    prev: Optional[Node<T>]
    
    next: Optional[Node<T>]
    

// --- Node_new.py ---
"""
DoublyLinkedList.new


Postconditions:
    - head is None
    - tail is None

"""

from node import Node


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


Node.new = new

del new


# ========== Generated tests ==========

def test_push_front_pop_front():
    let mut list = DoublyLinkedList::new();
    list.push_front(1)list.push_front(2)
    assert list.pop_front() == Some(2)assert list.pop_front() == Some(1)

def test_push_back_pop_back():
    let mut list = DoublyLinkedList::new();
    list.push_back(1)list.push_back(2)
    assert list.pop_back() == Some(2)assert list.pop_back() == Some(1)

def test_mixed_operations():
    let mut list = DoublyLinkedList::new();
    list.push_front(1)list.push_back(3)list.push_front(0)
    assert list.pop_front() == Some(0)assert list.pop_back() == Some(3)assert list.pop_back() == Some(1)


