// --- Graph.ts ---
/**
 * Graph
 * Time complexity: O(V+E) for traversal

 * Space complexity: O(V+E)


 * Invariants:
 * - all edges reference valid vertices
 * - vertex count >= 0

 */


export class Graph<T> {

    
    public adjacencyList: HashMap<T, Vec<T>>;
    
    public directed: boolean;
    
}

// --- Graph_new.ts ---
/**
 * Graph.new
 * @param directed - boolean

 * @returns Self



 * Postconditions:
 * - vertex_count == 0
 * - edge_count == 0

 */

import { Graph } from './graph';


(Graph.prototype as any).new = function <T>(directed: boolean): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('add_vertex_and_edge', () => {
    it('should pass', () => {
        let mut g = Graph::new(false);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        expect(g.has_vertex(1)).toBe(true);expect(g.has_vertex(2)).toBe(true);expect(g.has_edge(1, 2)).toBe(true);expect(g.vertex_count()).toBe(2);expect(g.edge_count()).toBe(1);
    });
});

describe('undirected_graph_symmetric_edges', () => {
    it('should pass', () => {
        let mut g = Graph::new(false);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        expect(g.has_edge(1, 2)).toBe(true);expect(g.has_edge(2, 1)).toBe(true);
    });
});

describe('directed_graph_no_symmetry', () => {
    it('should pass', () => {
        let mut g = Graph::new(true);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        expect(g.has_edge(1, 2)).toBe(true);expect(!g.has_edge(2, 1)).toBe(true);
    });
});


