// ========== Generated xUnit tests ==========

public class insert_and_containsTests
{
    [Fact]
    public void insert_and_contains_Test()
    {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(5);bst.insert(3);bst.insert(7);
        // Assertions
        Assert.IsTrue(bst.contains(5));Assert.IsTrue(bst.contains(3));Assert.IsTrue(bst.contains(7));Assert.IsTrue(!bst.contains(10));
    }
}

public class inorder_returns_sortedTests
{
    [Fact]
    public void inorder_returns_sorted_Test()
    {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(5);bst.insert(3);bst.insert(7);bst.insert(1);bst.insert(9);
        // Assertions
        Assert.AreEqual(bst.inorder(), vec![1, 3, 5, 7, 9]);
    }
}

public class duplicate_insert_returns_falseTests
{
    [Fact]
    public void duplicate_insert_returns_false_Test()
    {
        // Setup
        let mut bst = BinarySearchTree::new();
        // Actions
        bst.insert(10);
        // Assertions
        Assert.AreEqual(bst.insert(10), false);
    }
}

}
