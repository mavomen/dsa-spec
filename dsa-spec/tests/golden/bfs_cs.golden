// ========== Generated xUnit tests ==========

public class bfs_level_orderTests
{
    [Fact]
    public void bfs_level_order_Test()
    {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_vertex(4);
g.add_edge(1, 2);
g.add_edge(1, 3);
g.add_edge(2, 4);

        // Actions
        
        // Assertions
        let order = bfs(&g, 1);;Assert.AreEqual(order[0], 1);Assert.IsTrue(order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2);Assert.AreEqual(order[3], 4);
    }
}

public class bfs_disconnectedTests
{
    [Fact]
    public void bfs_disconnected_Test()
    {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

        // Actions
        
        // Assertions
        Assert.AreEqual(bfs(&g, 1), vec![1]);
    }
}

public class bfs_single_nodeTests
{
    [Fact]
    public void bfs_single_node_Test()
    {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(42);

        // Actions
        
        // Assertions
        Assert.AreEqual(bfs(&g, 42), vec![42]);
    }
}

