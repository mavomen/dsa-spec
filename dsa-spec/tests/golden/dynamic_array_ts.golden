// --- DynamicArray.ts ---
/**
 * DynamicArray
 * Time complexity: O(1) amortized push, O(n) insert/remove

 * Space complexity: O(n)


 * Invariants:
 * - length >= 0
 * - capacity >= length

 */


export class DynamicArray<T> {

    
    public data: T[];
    
    public len: number;
    
}

// --- DynamicArray_new.ts ---
/**
 * DynamicArray.new

 * @returns Self



 * Postconditions:
 * - length == 0
 * - capacity >= 0

 */

import { DynamicArray } from './dynamicarray';


(DynamicArray.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('push_increases_length', () => {
    it('should pass', () => {
        let mut arr = DynamicArray::new();
        arr.push(1);arr.push(2);
        expect(arr.len()).toBe(2);expect(!arr.is_empty()).toBe(true);
    });
});

describe('pop_returns_last_element', () => {
    it('should pass', () => {
        let mut arr = DynamicArray::new();
        arr.push(10);arr.push(20);
        expect(arr.pop()).toBe(Some(20));expect(arr.len()).toBe(1);
    });
});

describe('pop_empty_returns_none', () => {
    it('should pass', () => {
        let arr = DynamicArray::<i32>::new();
        
        expect(arr.pop()).toBe(None);
    });
});

describe('get_valid_index', () => {
    it('should pass', () => {
        let mut arr = DynamicArray::new(); arr.push(5);
        
        expect(arr.get(0)).toBe(Some(&5));
    });
});

describe('get_out_of_bounds', () => {
    it('should pass', () => {
        let mut arr = DynamicArray::new(); arr.push(5);
        
        expect(arr.get(1)).toBe(None);
    });
});


