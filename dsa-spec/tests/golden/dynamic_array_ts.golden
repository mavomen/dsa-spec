// ========== Generated Jest tests ==========

describe('push_increases_length', () => {
    it('should work', () => {
        // Setup
        let mut arr = DynamicArray::new();
        // Actions
        arr.push(1);arr.push(2);
        // Assertions
        expect(arr.len()).toBe(2);expect(!arr.is_empty()).toBe(true);
    });
});

describe('pop_returns_last_element', () => {
    it('should work', () => {
        // Setup
        let mut arr = DynamicArray::new();
        // Actions
        arr.push(10);arr.push(20);
        // Assertions
        expect(arr.pop()).toBe(Some(20));expect(arr.len()).toBe(1);
    });
});

describe('pop_empty_returns_none', () => {
    it('should work', () => {
        // Setup
        let arr = DynamicArray::<i32>::new();
        // Actions
        
        // Assertions
        expect(arr.pop()).toBe(None);
    });
});

describe('get_valid_index', () => {
    it('should work', () => {
        // Setup
        let mut arr = DynamicArray::new(); arr.push(5);
        // Actions
        
        // Assertions
        expect(arr.get(0)).toBe(Some(&5));
    });
});

describe('get_out_of_bounds', () => {
    it('should work', () => {
        // Setup
        let mut arr = DynamicArray::new(); arr.push(5);
        // Actions
        
        // Assertions
        expect(arr.get(1)).toBe(None);
    });
});

