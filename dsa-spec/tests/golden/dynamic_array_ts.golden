/**
 * DynamicArray

 * Time complexity: O(1) amortized push, O(n) insert/remove


 * Space complexity: O(n)


 * Invariants:

 * - length >= 0

 * - capacity >= length


 */



export interface DynamicArray<T extends Clone> {
    
    data: T[];
    
    len: number;
    
}

