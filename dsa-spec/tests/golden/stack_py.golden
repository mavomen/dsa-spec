"""
Stack

Time complexity: O(1) push/pop, O(n) search


Space complexity: O(n)


# Invariants

# - length >= 0


"""

from dataclasses import dataclass
from typing import TypeVar, Generic, Optional, List, Dict
import pytest



T = TypeVar('T')


@dataclass
class Stack(Generic[T]):
    """Stack"""
    
    items: List[T]
    

    
    def new(self) -> Self:
        """new.
        
        

        Returns:
            Self
        
        
        

        Postconditions:
        
            - length == 0
        
        
        """
        
        # TODO: Implement new
        raise NotImplementedError
    
    def push(self, item: T) -> None:
        """push.
        

        Args:
        
            item: T
        
        
        
        

        Postconditions:
        
            - length == old.length + 1
        
            - top == item
        
        
        """
        
        # TODO: Implement push
        raise NotImplementedError
    
    def pop(self) -> Optional[T]:
        """pop.
        
        

        Returns:
            Optional[T]
        
        

        Preconditions:
        
            - length > 0
        
        

        Postconditions:
        
            - length == old.length - 1
        
        
        """
        
        # TODO: Implement pop
        raise NotImplementedError
    
    def peek(self) -> Optional[T]:
        """peek.
        
        

        Returns:
            Optional[T]
        
        

        Preconditions:
        
            - length > 0
        
        
        
        """
        
        # TODO: Implement peek
        raise NotImplementedError
    
    def is_empty(self) -> bool:
        """is_empty.
        
        

        Returns:
            bool
        
        
        
        
        """
        
        # TODO: Implement is_empty
        raise NotImplementedError
    
    def len(self) -> int:
        """len.
        
        

        Returns:
            int
        
        
        
        
        """
        
        # TODO: Implement len
        raise NotImplementedError
    



# ========== Generated pytest tests ==========

def test_push_and_pop():
    """Test: push_and_pop"""
    let mut s = Stack::new();
    s.push(1)s.push(2)
    assert s.pop() == Some(2)assert s.pop() == Some(1)assert s.is_empty()

def test_peek_returns_top():
    """Test: peek_returns_top"""
    let mut s = Stack::new();
    s.push(42)
    assert s.peek() == Some(&42)

def test_pop_empty_returns_none():
    """Test: pop_empty_returns_none"""
    let mut s = Stack::<i32>::new();
    
    assert s.pop() == None

def test_len_tracks_elements():
    """Test: len_tracks_elements"""
    let mut s = Stack::new();
    s.push(10)s.push(20)
    assert s.len() == 2


if __name__ == "__main__":
    pytest.main([__file__])
