    let mut s = Stack::new();
    s.push(10)s.push(20)
    assert s.len() == 2


// --- Stack_pop.py ---
"""
Stack.pop

Preconditions:
    - length > 0


Postconditions:
    - length == old.length - 1

"""

from stack import Stack


def pop(self, ) -> Optional[T]:
