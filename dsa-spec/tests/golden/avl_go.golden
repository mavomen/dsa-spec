// AVLTree

// Time complexity: O(log n) search/insert/delete


// Space complexity: O(n)


// Invariants:

// - left.value < node.value < right.value

// - |left.height - right.height| <= 1

// - height = 1 + max(left.height, right.height)



package avltree

import "testing"





// AVLNodeInterface defines the contract for AVLNode
type AVLNodeInterface[T constraints.Ordered] interface {

	
	New() Self
	
	Insert(value T) bool
	
	Contains(value T) bool
	
	Inorder() []T
	
	Height() int32
	
	IsEmpty() bool
	
}


// AVLNode represents a AVLTree
type AVLNode[T constraints.Ordered] struct {
	
	Value T
	
	Left *AVLNode<T>
	
	Right *AVLNode<T>
	
	Height int32
	
}


