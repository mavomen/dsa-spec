// --- AVLNode.go ---
// AVLTree
 // Time complexity: O(log n) search/insert/delete

 // Space complexity: O(n)


// Invariants:
 // - left.value < node.value < right.value
 // - |left.height - right.height| <= 1
 // - height = 1 + max(left.height, right.height)


package avltree


type AVLNode[T constraints.Ordered] struct {

    
    Value T
    
    Left *AVLNode<T>
    
    Right *AVLNode<T>
    
    Height int32
    
}

func NewAVLNode[T constraints.Ordered]() *AVLNode[T] {
    return &AVLNode[T]{}
}

// --- AVLNode_new.go ---
// AVLTree.New

 // @returns Self



// Postconditions:
 // - root is None


package avltree


func (s *AVLNode[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestAVLNodeNewinsert_maintains_balance(t *testing.T) {
    let mut avl = AVLTree::new();
    avl.insert(1)avl.insert(2)avl.insert(3)
    if !(avl.contains(2)) { t.Errorf("assertion failed: avl.contains(2)") }if avl.height() != 2 { t.Errorf("got %v, want %v", avl.height(), 2) }if avl.inorder() != vec![1, 2, 3] { t.Errorf("got %v, want %v", avl.inorder(), vec![1, 2, 3]) }
}

func TestAVLNodeNewleft_heavy_rebalance(t *testing.T) {
    let mut avl = AVLTree::new();
    avl.insert(3)avl.insert(2)avl.insert(1)
    if avl.height() != 2 { t.Errorf("got %v, want %v", avl.height(), 2) }if avl.inorder() != vec![1, 2, 3] { t.Errorf("got %v, want %v", avl.inorder(), vec![1, 2, 3]) }
}

func TestAVLNodeNewmultiple_inserts_stay_balanced(t *testing.T) {
    let mut avl = AVLTree::new();
    avl.insert(10)avl.insert(20)avl.insert(30)avl.insert(40)avl.insert(50)avl.insert(25)
    if !(avl.height() <= 3) { t.Errorf("assertion failed: avl.height() <= 3") }
}


