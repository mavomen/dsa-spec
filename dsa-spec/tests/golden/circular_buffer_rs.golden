// --- CircularBuffer.rs ---
/// CircularBuffer
/// Time complexity: O(1) enqueue/dequeue

/// Space complexity: O(n)

/// Invariants:
/// - length <= capacity
/// - 0 <= head < capacity
/// - 0 <= tail < capacity

#[derive(Debug, Clone)]
pub struct CircularBuffer<T>
where
    T: Clone + Default,
{
    pub buffer: Vec<Option<T>>,

    pub head: usize,

    pub tail: usize,

    pub size: usize,

    pub capacity: usize,
}

impl<T> CircularBuffer<T> {
    pub fn new() -> Self {
        Self {
            buffer: Default::default(),

            head: Default::default(),

            tail: Default::default(),

            size: Default::default(),

            capacity: Default::default(),
        }
    }
}

// --- CircularBuffer_new.rs ---
/// CircularBuffer.new
/// * `capacity` - usize

/// Returns: Self

/// Preconditions:
/// - capacity > 0

/// Postconditions:
/// - is_empty() == true
/// - capacity == capacity

impl<T> CircularBuffer<T> {
    pub fn new(&mut self, capacity: usize) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn enqueue_dequeue_fifo() {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);
        buf.enqueue(2);
        assert_eq!(buf.dequeue(), Some(1));
        assert_eq!(buf.dequeue(), Some(2));
    }

    #[test]
    fn full_buffer_prevents_enqueue() {
        let mut buf = CircularBuffer::new(1);
        buf.enqueue(42);
        assert!(buf.is_full());
        assert!(buf.enqueue(43).is_err());
    }

    #[test]
    fn empty_buffer_returns_none() {
        let buf = CircularBuffer::<i32>::new(5);

        assert_eq!(buf.dequeue(), None);
    }

    #[test]
    fn wrap_around_works() {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);
        buf.enqueue(2);
        buf.dequeue();
        buf.enqueue(3);
        buf.enqueue(4);
        assert_eq!(buf.dequeue(), Some(2));
        assert_eq!(buf.dequeue(), Some(3));
        assert_eq!(buf.dequeue(), Some(4));
    }
}

// --- CircularBuffer_enqueue.rs ---
/// CircularBuffer.enqueue
/// * `item` - T

/// Returns: Result<(), String>

/// Preconditions:
/// - size < capacity

/// Postconditions:
/// - size == old.size + 1

impl<T> CircularBuffer<T> {
    pub fn enqueue(&mut self, item: T) -> Result<(), String> {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn enqueue_dequeue_fifo() {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);
        buf.enqueue(2);
        assert_eq!(buf.dequeue(), Some(1));
        assert_eq!(buf.dequeue(), Some(2));
    }

    #[test]
    fn full_buffer_prevents_enqueue() {
        let mut buf = CircularBuffer::new(1);
        buf.enqueue(42);
        assert!(buf.is_full());
        assert!(buf.enqueue(43).is_err());
    }

    #[test]
    fn empty_buffer_returns_none() {
        let buf = CircularBuffer::<i32>::new(5);

        assert_eq!(buf.dequeue(), None);
    }

    #[test]
    fn wrap_around_works() {
        let mut buf = CircularBuffer::new(3);
        buf.enqueue(1);
        buf.enqueue(2);
        buf.dequeue();
        buf.enqueue(3);
        buf.enqueue(4);
        assert_eq!(buf.dequeue(), Some(2));
        assert_eq!(buf.dequeue(), Some(3));
        assert_eq!(buf.dequeue(), Some(4));
    }
}

