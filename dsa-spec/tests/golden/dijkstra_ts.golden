// ========== Generated Jest tests ==========

describe('simple_path', () => {
    it('should work', () => {
        // Setup
        let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
        // Actions
        graph.insert(0, vec![(1, 4), (2, 1)]);graph.insert(1, vec![(3, 1)]);graph.insert(2, vec![(1, 2), (3, 5)]);graph.insert(3, vec![]);let dist = dijkstra(&graph, 0);
        // Assertions
        expect(dist[&0]).toBe(0);expect(dist[&1]).toBe(3);expect(dist[&2]).toBe(1);expect(dist[&3]).toBe(4);
    });
});

describe('unreachable_vertex', () => {
    it('should work', () => {
        // Setup
        let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
        // Actions
        graph.insert(0, vec![(1, 1)]);graph.insert(1, vec![]);graph.insert(2, vec![]);let dist = dijkstra(&graph, 0);
        // Assertions
        expect(dist[&0]).toBe(0);expect(dist[&1]).toBe(1);expect(!dist.contains_key(&2)).toBe(true);
    });
});

