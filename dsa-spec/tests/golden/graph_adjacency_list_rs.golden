// --- Graph.rs ---
/// Graph
/// Time complexity: O(V+E) for traversal

/// Space complexity: O(V+E)


/// Invariants:
/// - all edges reference valid vertices
/// - vertex count >= 0



#[derive(Debug, Clone)]
pub struct Graph<T>
where T: Clone + Hash + Eq 

    
    pub adjacency_list: HashMap<T, Vec<T>>,
    
    pub directed: bool,
    
}

impl<T> Graph<T> {
    pub fn new() -> Self {
        Self {
            
            adjacency_list: Default::default(),
            
            directed: Default::default(),
            
        }
    }
}

// --- Graph_new.rs ---
/// Graph.new
/// * `directed` - bool

/// Returns: Self

/// Postconditions:
/// - vertex_count == 0
/// - edge_count == 0

impl<T> Graph<T> {
    pub fn new(&mut self, directed: bool) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn add_vertex_and_edge() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_vertex(1));
        assert!(g.has_vertex(2));
        assert!(g.has_edge(1, 2));
        assert_eq!(g.vertex_count(), 2);
        assert_eq!(g.edge_count(), 1);
    }

    #[test]
    fn undirected_graph_symmetric_edges() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_edge(1, 2));
        assert!(g.has_edge(2, 1));
    }

    #[test]
    fn directed_graph_no_symmetry() {
        let mut g = Graph::new(true);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_edge(1, 2));
        assert!(!g.has_edge(2, 1));
    }
}

