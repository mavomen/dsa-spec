/// Graph

/// Time complexity: O(V+E) for traversal

/// Space complexity: O(V+E)

///
/// # Invariants

/// - all edges reference valid vertices

/// - vertex count >= 0

pub struct Graph<T: Clone + Hash + Eq> {
    adjacency_list: HashMap<T, Vec<T>>,

    directed: bool,
}

