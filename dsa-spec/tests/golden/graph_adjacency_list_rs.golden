#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_add_vertex_and_edge() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_vertex(1));
        assert!(g.has_vertex(2));
        assert!(g.has_edge(1, 2));
        assert_eq!(g.vertex_count(), 2);
        assert_eq!(g.edge_count(), 1);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_undirected_graph_symmetric_edges() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_edge(1, 2));
        assert!(g.has_edge(2, 1));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_directed_graph_no_symmetry() {
        let mut g = Graph::new(true);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_edge(1, 2);
        assert!(g.has_edge(1, 2));
        assert!(!g.has_edge(2, 1));
    }
}
