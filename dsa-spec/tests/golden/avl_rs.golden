// --- AVLNode.rs ---
/// AVLTree
/// Time complexity: O(log n) search/insert/delete

/// Space complexity: O(n)


/// Invariants:
/// - left.value < node.value < right.value
/// - |left.height - right.height| <= 1
/// - height = 1 + max(left.height, right.height)



#[derive(Debug, Clone)]
pub struct AVLNode<T>
where T: Ord + Clone 

    
    pub value: T,
    
    pub left: Option<Box<AVLNode<T>>>,
    
    pub right: Option<Box<AVLNode<T>>>,
    
    pub height: i32,
    
}

impl<T> AVLNode<T> {
    pub fn new() -> Self {
        Self {
            
            value: Default::default(),
            
            left: Default::default(),
            
            right: Default::default(),
            
            height: Default::default(),
            
        }
    }
}

// --- AVLNode_new.rs ---
/// AVLTree.new

/// Returns: Self

/// Postconditions:
/// - root is None

impl<T> AVLNode<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn insert_maintains_balance() {
        let mut avl = AVLTree::new();
        avl.insert(1);
        avl.insert(2);
        avl.insert(3);
        assert!(avl.contains(2));
        assert_eq!(avl.height(), 2);
        assert_eq!(avl.inorder(), vec![1, 2, 3]);
    }

    #[test]
    fn left_heavy_rebalance() {
        let mut avl = AVLTree::new();
        avl.insert(3);
        avl.insert(2);
        avl.insert(1);
        assert_eq!(avl.height(), 2);
        assert_eq!(avl.inorder(), vec![1, 2, 3]);
    }

    #[test]
    fn multiple_inserts_stay_balanced() {
        let mut avl = AVLTree::new();
        avl.insert(10);
        avl.insert(20);
        avl.insert(30);
        avl.insert(40);
        avl.insert(50);
        avl.insert(25);
        assert!(avl.height() <= 3);
    }
}

