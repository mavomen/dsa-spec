// --- BFSMethods.rs ---
/// BFS

/// Time complexity: O(V + E)

/// Space complexity: O(V)

///
/// # Invariants

/// - visited set contains no duplicates

/// - all visited vertices exist in graph

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_bfs_level_order() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);
        g.add_vertex(3);
        g.add_vertex(4);
        g.add_edge(1, 2);
        g.add_edge(1, 3);
        g.add_edge(2, 4);

        let order = bfs(&g, 1);
        assert_eq!(order[0], 1);
        assert!(order[1] == 2 && order[2] == 3 || order[1] == 3 && order[2] == 2);
        assert_eq!(order[3], 4);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_bfs_disconnected() {
        let mut g = Graph::new(false);
        g.add_vertex(1);
        g.add_vertex(2);

        assert_eq!(bfs(&g, 1), vec![1]);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_bfs_single_node() {
        let mut g = Graph::new(false);
        g.add_vertex(42);

        assert_eq!(bfs(&g, 42), vec![42]);
    }
}
