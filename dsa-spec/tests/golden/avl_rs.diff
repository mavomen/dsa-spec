#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_insert_maintains_balance() {
        let mut avl = AVLTree::new();
        avl.insert(1);
        avl.insert(2);
        avl.insert(3);
        assert!(avl.contains(2));
        assert_eq!(avl.height(), 2);
        assert_eq!(avl.inorder(), vec![1, 2, 3]);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_left_heavy_rebalance() {
        let mut avl = AVLTree::new();
        avl.insert(3);
        avl.insert(2);
        avl.insert(1);
        assert_eq!(avl.height(), 2);
        assert_eq!(avl.inorder(), vec![1, 2, 3]);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_multiple_inserts_stay_balanced() {
        let mut avl = AVLTree::new();
        avl.insert(10);
        avl.insert(20);
        avl.insert(30);
        avl.insert(40);
        avl.insert(50);
        avl.insert(25);
        assert!(avl.height() <= 3);
    }
}
