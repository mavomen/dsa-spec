// --- AVLNode.ts ---
/**
 * AVLTree
 * Time complexity: O(log n) search/insert/delete

 * Space complexity: O(n)


 * Invariants:
 * - left.value < node.value < right.value
 * - |left.height - right.height| <= 1
 * - height = 1 + max(left.height, right.height)

 */


export class AVLNode<T> {

    
    public value: T;
    
    public left: AVLNode<T> | null;
    
    public right: AVLNode<T> | null;
    
    public height: number;
    
}

// --- AVLNode_new.ts ---
/**
 * AVLTree.new

 * @returns Self



 * Postconditions:
 * - root is None

 */

import { AVLNode } from './avlnode';


(AVLNode.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('insert_maintains_balance', () => {
    it('should pass', () => {
        let mut avl = AVLTree::new();
        avl.insert(1);avl.insert(2);avl.insert(3);
        expect(avl.contains(2)).toBe(true);expect(avl.height()).toBe(2);expect(avl.inorder()).toBe(vec![1, 2, 3]);
    });
});

describe('left_heavy_rebalance', () => {
    it('should pass', () => {
        let mut avl = AVLTree::new();
        avl.insert(3);avl.insert(2);avl.insert(1);
        expect(avl.height()).toBe(2);expect(avl.inorder()).toBe(vec![1, 2, 3]);
    });
});

describe('multiple_inserts_stay_balanced', () => {
    it('should pass', () => {
        let mut avl = AVLTree::new();
        avl.insert(10);avl.insert(20);avl.insert(30);avl.insert(40);avl.insert(50);avl.insert(25);
        expect(avl.height() <= 3).toBe(true);
    });
});


