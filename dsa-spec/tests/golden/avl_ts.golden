// ========== Generated Jest tests ==========

describe('insert_maintains_balance', () => {
    it('should work', () => {
        // Setup
        let mut avl = AVLTree::new();
        // Actions
        avl.insert(1);avl.insert(2);avl.insert(3);
        // Assertions
        expect(avl.contains(2)).toBe(true);expect(avl.height()).toBe(2);expect(avl.inorder()).toBe(vec![1, 2, 3]);
    });
});

describe('left_heavy_rebalance', () => {
    it('should work', () => {
        // Setup
        let mut avl = AVLTree::new();
        // Actions
        avl.insert(3);avl.insert(2);avl.insert(1);
        // Assertions
        expect(avl.height()).toBe(2);expect(avl.inorder()).toBe(vec![1, 2, 3]);
    });
});

describe('multiple_inserts_stay_balanced', () => {
    it('should work', () => {
        // Setup
        let mut avl = AVLTree::new();
        // Actions
        avl.insert(10);avl.insert(20);avl.insert(30);avl.insert(40);avl.insert(50);avl.insert(25);
        // Assertions
        expect(avl.height() <= 3).toBe(true);
    });
});

