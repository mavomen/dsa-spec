// ========== Generated Jest tests ==========

describe('dfs_simple_path', () => {
    it('should work', () => {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);

        // Actions
        
        // Assertions
        expect(dfs(&g, 1)).toBe(vec![1, 2, 3]);
    });
});

describe('dfs_disconnected', () => {
    it('should work', () => {
        // Setup
        let mut g = Graph::new(false);
g.add_vertex(1);
g.add_vertex(2);

        // Actions
        
        // Assertions
        expect(dfs(&g, 1)).toBe(vec![1]);
    });
});

describe('dfs_cyclic_graph', () => {
    it('should work', () => {
        // Setup
        let mut g = Graph::new(true);
g.add_vertex(1);
g.add_vertex(2);
g.add_vertex(3);
g.add_edge(1, 2);
g.add_edge(2, 3);
g.add_edge(3, 1);

        // Actions
        
        // Assertions
        expect(dfs(&g, 1).len()).toBe(3);
    });
});

