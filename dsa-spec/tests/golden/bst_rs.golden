#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_insert_and_contains() {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);
        bst.insert(3);
        bst.insert(7);
        assert!(bst.contains(5));
        assert!(bst.contains(3));
        assert!(bst.contains(7));
        assert!(!bst.contains(10));
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_inorder_returns_sorted() {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);
        bst.insert(3);
        bst.insert(7);
        bst.insert(1);
        bst.insert(9);
        assert_eq!(bst.inorder(), vec![1, 3, 5, 7, 9]);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_duplicate_insert_returns_false() {
        let mut bst = BinarySearchTree::new();
        bst.insert(10);
        assert_eq!(bst.insert(10), false);
    }
}
