// --- BSTNode.rs ---
/// BinarySearchTree
/// Time complexity: O(log n) average, O(n) worst

/// Space complexity: O(n)

/// Invariants:
/// - left.value < node.value < right.value
/// - no duplicate values

#[derive(Debug, Clone)]
pub struct BSTNode<T>
where
    T: Ord + Clone,
{
    pub value: T,

    pub left: Option<Box<BSTNode<T>>>,

    pub right: Option<Box<BSTNode<T>>>,
}

impl<T> BSTNode<T> {
    pub fn new() -> Self {
        Self {
            value: Default::default(),

            left: Default::default(),

            right: Default::default(),
        }
    }
}

// --- BSTNode_new.rs ---
/// BinarySearchTree.new

/// Returns: Self

/// Postconditions:
/// - root is None

impl<T> BSTNode<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn insert_and_contains() {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);
        bst.insert(3);
        bst.insert(7);
        assert!(bst.contains(5));
        assert!(bst.contains(3));
        assert!(bst.contains(7));
        assert!(!bst.contains(10));
    }

    #[test]
    fn inorder_returns_sorted() {
        let mut bst = BinarySearchTree::new();
        bst.insert(5);
        bst.insert(3);
        bst.insert(7);
        bst.insert(1);
        bst.insert(9);
        assert_eq!(bst.inorder(), vec![1, 3, 5, 7, 9]);
    }

    #[test]
    fn duplicate_insert_returns_false() {
        let mut bst = BinarySearchTree::new();
        bst.insert(10);
        assert_eq!(bst.insert(10), false);
    }
}

