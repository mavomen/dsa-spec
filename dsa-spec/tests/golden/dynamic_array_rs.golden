// --- DynamicArray.rs ---
/// DynamicArray
/// Time complexity: O(1) amortized push, O(n) insert/remove

/// Space complexity: O(n)


/// Invariants:
/// - length >= 0
/// - capacity >= length



#[derive(Debug, Clone)]
pub struct DynamicArray<T>
where T: Clone 

    
    pub data: Vec<T>,
    
    pub len: usize,
    
}

impl<T> DynamicArray<T> {
    pub fn new() -> Self {
        Self {
            
            data: Vec::new(),
            
            len: Default::default(),
            
        }
    }
}

// --- DynamicArray_new.rs ---
/// DynamicArray.new

/// Returns: Self

/// Postconditions:
/// - length == 0
/// - capacity >= 0

impl<T> DynamicArray<T> {
    pub fn new(&mut self) -> Self {
        todo!()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn push_increases_length() {
        let mut arr = DynamicArray::new();
        arr.push(1);
        arr.push(2);
        assert_eq!(arr.len(), 2);
        assert!(!arr.is_empty());
    }

    #[test]
    fn pop_returns_last_element() {
        let mut arr = DynamicArray::new();
        arr.push(10);
        arr.push(20);
        assert_eq!(arr.pop(), Some(20));
        assert_eq!(arr.len(), 1);
    }

    #[test]
    fn pop_empty_returns_none() {
        let arr = DynamicArray::<i32>::new();

        assert_eq!(arr.pop(), None);
    }

    #[test]
    fn get_valid_index() {
        let mut arr = DynamicArray::new();
        arr.push(5);

        assert_eq!(arr.get(0), Some(&5));
    }

    #[test]
    fn get_out_of_bounds() {
        let mut arr = DynamicArray::new();
        arr.push(5);

        assert_eq!(arr.get(1), None);
    }
}

