// --- DynamicArray_pop.rs ---
/// DynamicArray.pop

/// Returns: Option<T>

/// Preconditions:
/// - length > 0

/// Postconditions:
/// - length == old.length - 1

impl<T> DynamicArray<T> {
    pub fn pop(&mut self) -> Option<T> {
        todo!()
    }
}

