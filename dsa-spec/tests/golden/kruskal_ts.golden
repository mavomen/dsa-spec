// ========== Generated Jest tests ==========

describe('simple_graph_mst', () => {
    it('should work', () => {
        // Setup
        let vertices = 4;
        // Actions
        let edges = vec![(0, 1, 10), (0, 2, 6), (0, 3, 5), (1, 3, 15), (2, 3, 4)];let mst = kruskal(vertices, edges);
        // Assertions
        expect(mst.len()).toBe(3);expect(total_weight(&mst)).toBe(19);
    });
});

describe('single_vertex', () => {
    it('should work', () => {
        // Setup
        let vertices = 1;
        // Actions
        let edges: Vec<(usize, usize, usize)> = vec![];let mst = kruskal(vertices, edges);
        // Assertions
        expect(mst.len()).toBe(0);
    });
});

describe('disconnected_graph', () => {
    it('should work', () => {
        // Setup
        let vertices = 3;
        // Actions
        let edges = vec![(0, 1, 5)];let mst = kruskal(vertices, edges);
        // Assertions
        expect(mst.len()).toBe(1);
    });
});

