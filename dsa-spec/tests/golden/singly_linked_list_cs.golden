// --- Node.cs ---
/// <summary>
/// SinglyLinkedList

/// Time complexity: O(1) prepend, O(n) append/search


/// Space complexity: O(n)


/// Invariants:

/// - no cycles

/// - head is None iff tail is None


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace SinglyLinkedList
{
    public partial class Node<T>
    where T : Clone

    {
        
        public T Value { get; set; }
        
        public Node<T>? Next { get; set; }
        
    }
}

// --- Node.New.cs ---
namespace SinglyLinkedList
{
    public partial class Node<T>
    where T : Clone

    {
        /// <summary>
        /// New.
        /// </summary>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - head is None
        
        /// </remarks>
        
        
        public Self New()
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class Nodeprepend_pop_frontTests
{
    [Fact]
    public void prepend_pop_front_Test()
    {
        let mut list = SinglyLinkedList::new();
        list.prepend(1);list.prepend(2);
        Assert.AreEqual(list.pop_front(), Some(2));Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class Nodeappend_orderTests
{
    [Fact]
    public void append_order_Test()
    {
        let mut list = SinglyLinkedList::new();
        list.append(1);list.append(2);
        Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class Nodepop_front_emptyTests
{
    [Fact]
    public void pop_front_empty_Test()
    {
        let list = SinglyLinkedList::<i32>::new();
        
        Assert.AreEqual(list.pop_front(), None);
    }
}


