// ========== Generated xUnit tests ==========

public class prepend_pop_frontTests
{
    [Fact]
    public void prepend_pop_front_Test()
    {
        // Setup
        let mut list = SinglyLinkedList::new();
        // Actions
        list.prepend(1);list.prepend(2);
        // Assertions
        Assert.AreEqual(list.pop_front(), Some(2));Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class append_orderTests
{
    [Fact]
    public void append_order_Test()
    {
        // Setup
        let mut list = SinglyLinkedList::new();
        // Actions
        list.append(1);list.append(2);
        // Assertions
        Assert.AreEqual(list.pop_front(), Some(1));
    }
}

public class pop_front_emptyTests
{
    [Fact]
    public void pop_front_empty_Test()
    {
        // Setup
        let list = SinglyLinkedList::<i32>::new();
        // Actions
        
        // Assertions
        Assert.AreEqual(list.pop_front(), None);
    }
}

