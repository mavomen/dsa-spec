// ========== Generated xUnit tests ==========

public class push_and_popTests
{
    [Fact]
    public void push_and_pop_Test()
    {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(1);s.push(2);
        // Assertions
        Assert.AreEqual(s.pop(), Some(2));Assert.AreEqual(s.pop(), Some(1));Assert.IsTrue(s.is_empty());
    }
}

public class peek_returns_topTests
{
    [Fact]
    public void peek_returns_top_Test()
    {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(42);
        // Assertions
        Assert.AreEqual(s.peek(), Some(&42));
    }
}

public class pop_empty_returns_noneTests
{
    [Fact]
    public void pop_empty_returns_none_Test()
    {
        // Setup
        let mut s = Stack::<i32>::new();
        // Actions
        
        // Assertions
        Assert.AreEqual(s.pop(), None);
    }
}

public class len_tracks_elementsTests
{
    [Fact]
    public void len_tracks_elements_Test()
    {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(10);s.push(20);
        // Assertions
        Assert.AreEqual(s.len(), 2);
    }
}

}
