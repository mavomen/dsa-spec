// --- Stack.cs ---
/// <summary>
/// Stack

/// Time complexity: O(1) push/pop, O(n) search


/// Space complexity: O(n)


/// Invariants:

/// - length >= 0


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace Stack
{
    public partial class Stack<T>
    where T : Clone

    {
        
        public List<T> Items { get; set; }
        
    }
}

// --- Stack.New.cs ---
namespace Stack
{
    public partial class Stack<T>
    where T : Clone

    {
        /// <summary>
        /// New.
        /// </summary>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - length == 0
        
        /// </remarks>
        
        
        public Self New()
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class Stackpush_and_popTests
{
    [Fact]
    public void push_and_pop_Test()
    {
        let mut s = Stack::new();
        s.push(1);s.push(2);
        Assert.AreEqual(s.pop(), Some(2));Assert.AreEqual(s.pop(), Some(1));Assert.IsTrue(s.is_empty());
    }
}

public class Stackpeek_returns_topTests
{
    [Fact]
    public void peek_returns_top_Test()
    {
        let mut s = Stack::new();
        s.push(42);
        Assert.AreEqual(s.peek(), Some(&42));
    }
}

public class Stackpop_empty_returns_noneTests
{
    [Fact]
    public void pop_empty_returns_none_Test()
    {
        let mut s = Stack::<i32>::new();
        
        Assert.AreEqual(s.pop(), None);
    }
}

public class Stacklen_tracks_elementsTests
{
    [Fact]
    public void len_tracks_elements_Test()
    {
        let mut s = Stack::new();
        s.push(10);s.push(20);
        Assert.AreEqual(s.len(), 2);
    }
}


