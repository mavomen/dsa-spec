// ========== Generated xUnit tests ==========

public class simple_pathTests
{
    [Fact]
    public void simple_path_Test()
    {
        // Setup
        let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
        // Actions
        graph.insert(0, vec![(1, 4), (2, 1)]);graph.insert(1, vec![(3, 1)]);graph.insert(2, vec![(1, 2), (3, 5)]);graph.insert(3, vec![]);let dist = dijkstra(&graph, 0);
        // Assertions
        Assert.AreEqual(dist[&0], 0);Assert.AreEqual(dist[&1], 3);Assert.AreEqual(dist[&2], 1);Assert.AreEqual(dist[&3], 4);
    }
}

public class unreachable_vertexTests
{
    [Fact]
    public void unreachable_vertex_Test()
    {
        // Setup
        let mut graph: HashMap<usize, Vec<(usize, usize)>> = HashMap::new();
        // Actions
        graph.insert(0, vec![(1, 1)]);graph.insert(1, vec![]);graph.insert(2, vec![]);let dist = dijkstra(&graph, 0);
        // Assertions
        Assert.AreEqual(dist[&0], 0);Assert.AreEqual(dist[&1], 1);Assert.IsTrue(!dist.contains_key(&2));
    }
}

}
