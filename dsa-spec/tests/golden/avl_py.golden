// --- AVLNode.py ---
"""
AVLTree
Time complexity: O(log n) search/insert/delete
Space complexity: O(n)

Invariants:
    - left.value < node.value < right.value
    - |left.height - right.height| <= 1
    - height = 1 + max(left.height, right.height)

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict


T = TypeVar('T')



@dataclass
class AVLNode(Generic[T]):
    """AVLTree"""
    
    value: T
    
    left: Optional[AVLNode<T>]
    
    right: Optional[AVLNode<T>]
    
    height: int
    

// --- AVLNode_new.py ---
"""
AVLTree.new


Postconditions:
    - root is None

"""

from avlnode import AVLNode


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


AVLNode.new = new

del new


# ========== Generated tests ==========

def test_insert_maintains_balance():
    let mut avl = AVLTree::new();
    avl.insert(1)avl.insert(2)avl.insert(3)
    assert avl.contains(2)assert avl.height() == 2assert avl.inorder() == vec![1, 2, 3]

def test_left_heavy_rebalance():
    let mut avl = AVLTree::new();
    avl.insert(3)avl.insert(2)avl.insert(1)
    assert avl.height() == 2assert avl.inorder() == vec![1, 2, 3]

def test_multiple_inserts_stay_balanced():
    let mut avl = AVLTree::new();
    avl.insert(10)avl.insert(20)avl.insert(30)avl.insert(40)avl.insert(50)avl.insert(25)
    assert avl.height() <= 3


