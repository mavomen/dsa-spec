        # TODO: Implement new
        raise NotImplementedError
    
    def enqueue(self, item: T) -> ():
        """
        
        Preconditions:
        - size < capacity
        
        
        Postconditions:
        - size == old.size + 1
        
        
        Raises:
            Exception: on error (from Result type)
        
        """
        
        # TODO: Implement enqueue
        raise NotImplementedError
    
    def dequeue(self) -> Optional[T]:
        """
        
        Preconditions:
        - size > 0
        
        
        Postconditions:
        - size == old.size - 1
        
        
