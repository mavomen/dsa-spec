// --- CircularBuffer.py ---
"""
CircularBuffer
Time complexity: O(1) enqueue/dequeue
Space complexity: O(n)

Invariants:
    - length <= capacity
    - 0 <= head < capacity
    - 0 <= tail < capacity

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict

T = TypeVar("T")


@dataclass
class CircularBuffer(Generic[T]):
    """CircularBuffer"""

    buffer: List[Optional[T]]

    head: int

    tail: int

    size: int

    capacity: int

// --- CircularBuffer_new.py ---
"""
CircularBuffer.new

Preconditions:
    - capacity > 0


Postconditions:
    - is_empty() == true
    - capacity == capacity

"""

from circularbuffer import CircularBuffer


def new(self, capacity: int) -> Self:
    """new."""
    
    raise NotImplementedError


CircularBuffer.new = new

del new


# ========== Generated tests ==========

def test_enqueue_dequeue_fifo():
    let mut buf = CircularBuffer::new(3);
    buf.enqueue(1)buf.enqueue(2)
    assert buf.dequeue() == Some(1)assert buf.dequeue() == Some(2)

def test_full_buffer_prevents_enqueue():
    let mut buf = CircularBuffer::new(1);
    buf.enqueue(42)
    assert buf.is_full()assert buf.enqueue(43).is_err()

def test_empty_buffer_returns_none():
    let buf = CircularBuffer::<i32>::new(5);
    
    assert buf.dequeue() == None

def test_wrap_around_works():
    let mut buf = CircularBuffer::new(3);
    buf.enqueue(1)buf.enqueue(2)buf.dequeue()buf.enqueue(3)buf.enqueue(4)
    assert buf.dequeue() == Some(2)assert buf.dequeue() == Some(3)assert buf.dequeue() == Some(4)


