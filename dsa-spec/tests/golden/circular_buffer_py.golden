"""
CircularBuffer.enqueue

Preconditions:
    - size < capacity


Postconditions:
    - size == old.size + 1

"""

from circularbuffer import CircularBuffer


def enqueue(self, item: T) -> ():
    """enqueue."""
    
    raise NotImplementedError


CircularBuffer.enqueue = enqueue

del enqueue


