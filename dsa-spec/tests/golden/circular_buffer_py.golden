"""
CircularBuffer

Time complexity: O(1) enqueue/dequeue


Space complexity: O(n)


# Invariants

# - length <= capacity

# - 0 <= head < capacity

# - 0 <= tail < capacity


"""

from dataclasses import dataclass
from typing import TypeVar, Generic, Optional, List, Dict
import pytest



T = TypeVar('T')


@dataclass
class CircularBuffer(Generic[T]):
    """CircularBuffer"""
    
    buffer: List[Optional[T]]
    
    head: int
    
    tail: int
    
    size: int
    
    capacity: int
    

    
    def new(self, capacity: int) -> Self:
        """
        
        Preconditions:
        - capacity > 0
        
        
        Postconditions:
        - is_empty() == true
        - capacity == capacity
        
        
