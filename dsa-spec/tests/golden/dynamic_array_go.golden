// --- DynamicArray.go ---
// DynamicArray
// Time complexity: O(1) amortized push, O(n) insert/remove

// Space complexity: O(n)

// Invariants:
// - length >= 0
// - capacity >= length

package dynamicarray

type DynamicArray[T any] struct {
	Data []T

	Len int
}

func NewDynamicArray[T any]() *DynamicArray[T] {
	return &DynamicArray[T]{}
}

// --- DynamicArray_new.go ---
// DynamicArray.New

 // @returns Self



// Postconditions:
 // - length == 0
 // - capacity >= 0


package dynamicarray


func (s *DynamicArray[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestDynamicArrayNewpush_increases_length(t *testing.T) {
    let mut arr = DynamicArray::new();
    arr.push(1)arr.push(2)
    if arr.len() != 2 { t.Errorf("got %v, want %v", arr.len(), 2) }if !(!arr.is_empty()) { t.Errorf("assertion failed: !arr.is_empty()") }
}

func TestDynamicArrayNewpop_returns_last_element(t *testing.T) {
    let mut arr = DynamicArray::new();
    arr.push(10)arr.push(20)
    if arr.pop() != Some(20) { t.Errorf("got %v, want %v", arr.pop(), Some(20)) }if arr.len() != 1 { t.Errorf("got %v, want %v", arr.len(), 1) }
}

func TestDynamicArrayNewpop_empty_returns_none(t *testing.T) {
    let arr = DynamicArray::<i32>::new();
    
    if arr.pop() != None { t.Errorf("got %v, want %v", arr.pop(), None) }
}

func TestDynamicArrayNewget_valid_index(t *testing.T) {
    let mut arr = DynamicArray::new(); arr.push(5);
    
    if arr.get(0) != Some(&5) { t.Errorf("got %v, want %v", arr.get(0), Some(&5)) }
}

func TestDynamicArrayNewget_out_of_bounds(t *testing.T) {
    let mut arr = DynamicArray::new(); arr.push(5);
    
    if arr.get(1) != None { t.Errorf("got %v, want %v", arr.get(1), None) }
}


