"""
SinglyLinkedList

Time complexity: O(1) prepend, O(n) append/search


Space complexity: O(n)


# Invariants

# - no cycles

# - head is None iff tail is None


"""

from dataclasses import dataclass
from typing import TypeVar, Generic, Optional, List, Dict
import pytest



T = TypeVar('T')


@dataclass
class Node(Generic[T]):
    """SinglyLinkedList"""
    
    value: T
    
    next: Optional[Node<T>]
    

    
    def new(self) -> Self:
        """new.
        
        

        Returns:
            Self
        
        
        

        Postconditions:
        
            - head is None
        
        
        """
        
        # TODO: Implement new
        raise NotImplementedError
    
    def prepend(self, value: T) -> None:
        """prepend.
        

        Args:
        
            value: T
        
        
        
        

        Postconditions:
        
            - head.value == value
        
            - list length increased by 1
        
        
        """
        
        # TODO: Implement prepend
        raise NotImplementedError
    
    def append(self, value: T) -> None:
        """append.
        

        Args:
        
            value: T
        
        
        
        

        Postconditions:
        
            - last element == value
        
        
        """
        
        # TODO: Implement append
        raise NotImplementedError
    
    def pop_front(self) -> Optional[T]:
        """pop_front.
        
        

        Returns:
            Optional[T]
        
        

        Preconditions:
        
            - !is_empty()
        
        

        Postconditions:
        
            - head == old.head.next
        
        
        """
        
        # TODO: Implement pop_front
        raise NotImplementedError
    
    def is_empty(self) -> bool:
        """is_empty.
        
        

        Returns:
            bool
        
        
        
        
        """
        
        # TODO: Implement is_empty
        raise NotImplementedError
    
    def len(self) -> int:
        """len.
        
        

        Returns:
            int
        
        
        
        
        """
        
        # TODO: Implement len
        raise NotImplementedError
    

T = TypeVar('T')


@dataclass
class SinglyLinkedList(Generic[T]):
    """SinglyLinkedList"""
    
    head: Optional[Node<T>]
    

    
