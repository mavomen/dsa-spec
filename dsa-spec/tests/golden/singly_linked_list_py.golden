// --- Node.py ---
"""
SinglyLinkedList
Time complexity: O(1) prepend, O(n) append/search
Space complexity: O(n)

Invariants:
    - no cycles
    - head is None iff tail is None

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict


T = TypeVar('T')



@dataclass
class Node(Generic[T]):
    """SinglyLinkedList"""
    
    value: T
    
    next: Optional[Node<T>]
    

// --- Node_new.py ---
"""
SinglyLinkedList.new


Postconditions:
    - head is None

"""

from node import Node


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


Node.new = new

del new


# ========== Generated tests ==========

def test_prepend_pop_front():
    let mut list = SinglyLinkedList::new();
    list.prepend(1)list.prepend(2)
    assert list.pop_front() == Some(2)assert list.pop_front() == Some(1)

def test_append_order():
    let mut list = SinglyLinkedList::new();
    list.append(1)list.append(2)
    assert list.pop_front() == Some(1)

def test_pop_front_empty():
    let list = SinglyLinkedList::<i32>::new();
    
    assert list.pop_front() == None


// --- Node_prepend.py ---
"""
SinglyLinkedList.prepend


Postconditions:
    - head.value == value
    - list length increased by 1

"""

from node import Node


def prepend(self, value: T) -> None:
    """prepend."""
    
    raise NotImplementedError


Node.prepend = prepend

del prepend


# ========== Generated tests ==========

