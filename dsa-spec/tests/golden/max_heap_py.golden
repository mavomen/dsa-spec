// --- MaxHeap.py ---
"""
MaxHeap
Time complexity: O(log n) insert/extract, O(1) peek
Space complexity: O(n)

Invariants:
    - parent value >= children values
    - tree is complete (all levels filled left-to-right)
    - size == data.len()

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict

T = TypeVar("T")


@dataclass
class MaxHeap(Generic[T]):
    """MaxHeap"""

    data: List[T]

// --- MaxHeap_new.py ---
"""
MaxHeap.new


Postconditions:
    - is_empty() == true
    - size() == 0

"""

from maxheap import MaxHeap


def new(self, ) -> Self:
    """new."""
    
    raise NotImplementedError


MaxHeap.new = new

del new


# ========== Generated tests ==========

def test_insert_and_extract_max():
    let mut heap = MaxHeap::new();
    heap.insert(3)heap.insert(5)heap.insert(1)heap.insert(4)
    assert heap.extract_max() == Some(5)assert heap.extract_max() == Some(4)assert heap.extract_max() == Some(3)assert heap.extract_max() == Some(1)assert heap.extract_max() == None

def test_peek_returns_largest():
    let mut heap = MaxHeap::new();
    heap.insert(10)heap.insert(20)
    assert *heap.peek().unwrap() == 20

def test_empty_heap_returns_none():
    let heap: MaxHeap<i32> = MaxHeap::new();
    
    assert heap.peek().is_none()assert heap.extract_max().is_none()assert heap.is_empty()

def test_size_tracks_insertions():
    let mut heap = MaxHeap::new();
    heap.insert(1)heap.insert(2)heap.insert(3)
    assert heap.size() == 3heap.extract_max()assert heap.size() == 2


