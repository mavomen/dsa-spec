# ========== Generated pytest tests ==========

def test_sort_unsorted_array():
    """Test: sort_unsorted_array"""
    let mut arr = vec![5, 3, 8, 1, 2];
    mergesort(&mut arr)
    assert arr == vec![1, 2, 3, 5, 8]

def test_sort_empty_array():
    """Test: sort_empty_array"""
    let mut arr: Vec<i32> = vec![];
    mergesort(&mut arr)
    assert arr == vec![]

def test_sort_single_element():
    """Test: sort_single_element"""
    let mut arr = vec![7];
    mergesort(&mut arr)
    assert arr == vec![7]

def test_sort_already_sorted():
    """Test: sort_already_sorted"""
    let mut arr = vec![1, 2, 3, 4, 5];
    mergesort(&mut arr)
    assert arr == vec![1, 2, 3, 4, 5]


