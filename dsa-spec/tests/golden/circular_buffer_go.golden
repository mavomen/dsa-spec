// ========== Generated tests ==========

func Testenqueue_dequeue_fifo(t *testing.T) {
	let mut buf = CircularBuffer::new(3);
	buf.enqueue(1)buf.enqueue(2)
	if buf.dequeue() != Some(1) { t.Errorf("got %v, want %v", buf.dequeue(), Some(1)) }if buf.dequeue() != Some(2) { t.Errorf("got %v, want %v", buf.dequeue(), Some(2)) }
}

func Testfull_buffer_prevents_enqueue(t *testing.T) {
	let mut buf = CircularBuffer::new(1);
	buf.enqueue(42)
	if !(buf.is_full()) { t.Errorf("assertion failed: buf.is_full()") }if !(buf.enqueue(43).is_err()) { t.Errorf("assertion failed: buf.enqueue(43).is_err()") }
}

func Testempty_buffer_returns_none(t *testing.T) {
	let buf = CircularBuffer::<i32>::new(5);
	
	if buf.dequeue() != None { t.Errorf("got %v, want %v", buf.dequeue(), None) }
}

func Testwrap_around_works(t *testing.T) {
	let mut buf = CircularBuffer::new(3);
	buf.enqueue(1)buf.enqueue(2)buf.dequeue()buf.enqueue(3)buf.enqueue(4)
	if buf.dequeue() != Some(2) { t.Errorf("got %v, want %v", buf.dequeue(), Some(2)) }if buf.dequeue() != Some(3) { t.Errorf("got %v, want %v", buf.dequeue(), Some(3)) }if buf.dequeue() != Some(4) { t.Errorf("got %v, want %v", buf.dequeue(), Some(4)) }
}

