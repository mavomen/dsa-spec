// --- KruskalMethods.rs ---
/// Kruskal

/// Time complexity: O(E log E)

/// Space complexity: O(V + E)

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_simple_graph_mst() {
        let vertices = 4;
        let edges = vec![(0, 1, 10), (0, 2, 6), (0, 3, 5), (1, 3, 15), (2, 3, 4)];
        let mst = kruskal(vertices, edges);
        assert_eq!(mst.len(), 3);
        assert_eq!(total_weight(&mst), 19);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_single_vertex() {
        let vertices = 1;
        let edges: Vec<(usize, usize, usize)> = vec![];
        let mst = kruskal(vertices, edges);
        assert_eq!(mst.len(), 0);
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_disconnected_graph() {
        let vertices = 3;
        let edges = vec![(0, 1, 5)];
        let mst = kruskal(vertices, edges);
        assert_eq!(mst.len(), 1);
    }
}
