// ========== Generated tests ==========

func Testfind_element_in_middle(t *testing.T) {
	let arr = vec![1, 3, 5, 7, 9];
	let result = binary_search(&arr, &5)
	if result != Some(2) { t.Errorf("got %v, want %v", result, Some(2)) }
}

func Testfind_first_element(t *testing.T) {
	let arr = vec![1, 3, 5, 7, 9];
	let result = binary_search(&arr, &1)
	if result != Some(0) { t.Errorf("got %v, want %v", result, Some(0)) }
}

func Testfind_last_element(t *testing.T) {
	let arr = vec![1, 3, 5, 7, 9];
	let result = binary_search(&arr, &9)
	if result != Some(4) { t.Errorf("got %v, want %v", result, Some(4)) }
}

func Testelement_not_found(t *testing.T) {
	let arr = vec![1, 3, 5, 7, 9];
	let result = binary_search(&arr, &4)
	if result != None { t.Errorf("got %v, want %v", result, None) }
}

func Testempty_array(t *testing.T) {
	let arr: Vec<i32> = vec![];
	let result = binary_search(&arr, &1)
	if result != None { t.Errorf("got %v, want %v", result, None) }
}

func Testsingle_element_found(t *testing.T) {
	let arr = vec![42];
	let result = binary_search(&arr, &42)
	if result != Some(0) { t.Errorf("got %v, want %v", result, Some(0)) }
}

func Testsingle_element_not_found(t *testing.T) {
	let arr = vec![42];
	let result = binary_search(&arr, &1)
	if result != None { t.Errorf("got %v, want %v", result, None) }
}

func Testduplicate_elements(t *testing.T) {
	let arr = vec![1, 2, 2, 2, 3];
	let result = binary_search(&arr, &2)
	if !(result.is_some()) { t.Errorf("assertion failed: result.is_some()") }let idx = result.unwrap();if !(idx >= 1 && idx <= 3) { t.Errorf("assertion failed: idx >= 1 && idx <= 3") }
}

