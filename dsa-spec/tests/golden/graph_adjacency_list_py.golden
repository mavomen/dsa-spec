// --- Graph.py ---
"""
Graph
Time complexity: O(V+E) for traversal
Space complexity: O(V+E)

Invariants:
    - all edges reference valid vertices
    - vertex count >= 0

"""

from dataclasses import dataclass
from typing import Generic, TypeVar, Optional, List, Dict

T = TypeVar("T")


@dataclass
class Graph(Generic[T]):
    """Graph"""

    adjacency_list: Dict[T, List[T]]

    directed: bool

// --- Graph_new.py ---
"""
Graph.new


Postconditions:
    - vertex_count == 0
    - edge_count == 0

"""

from graph import Graph


def new(self, directed: bool) -> Self:
    """new."""
    
    raise NotImplementedError


Graph.new = new

del new


# ========== Generated tests ==========

def test_add_vertex_and_edge():
    let mut g = Graph::new(false);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    assert g.has_vertex(1)assert g.has_vertex(2)assert g.has_edge(1, 2)assert g.vertex_count() == 2assert g.edge_count() == 1

def test_undirected_graph_symmetric_edges():
    let mut g = Graph::new(false);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    assert g.has_edge(1, 2)assert g.has_edge(2, 1)

def test_directed_graph_no_symmetry():
    let mut g = Graph::new(true);
    g.add_vertex(1)g.add_vertex(2)g.add_edge(1, 2)
    assert g.has_edge(1, 2)assert !g.has_edge(2, 1)


