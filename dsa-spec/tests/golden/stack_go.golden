// --- Stack.go ---
// Stack
// Time complexity: O(1) push/pop, O(n) search

// Space complexity: O(n)

// Invariants:
// - length >= 0

package stack

type Stack[T any] struct {
	Items []T
}

func NewStack[T any]() *Stack[T] {
	return &Stack[T]{}
}

// --- Stack_new.go ---
// Stack.New

 // @returns Self



// Postconditions:
 // - length == 0


package stack


func (s *Stack[T]) New() Self {

    
    panic("not implemented")
}

// ========== Generated tests ==========

func TestStackNewpush_and_pop(t *testing.T) {
    let mut s = Stack::new();
    s.push(1)s.push(2)
    if s.pop() != Some(2) { t.Errorf("got %v, want %v", s.pop(), Some(2)) }if s.pop() != Some(1) { t.Errorf("got %v, want %v", s.pop(), Some(1)) }if !(s.is_empty()) { t.Errorf("assertion failed: s.is_empty()") }
}

func TestStackNewpeek_returns_top(t *testing.T) {
    let mut s = Stack::new();
    s.push(42)
    if s.peek() != Some(&42) { t.Errorf("got %v, want %v", s.peek(), Some(&42)) }
}

func TestStackNewpop_empty_returns_none(t *testing.T) {
    let mut s = Stack::<i32>::new();
    
    if s.pop() != None { t.Errorf("got %v, want %v", s.pop(), None) }
}

func TestStackNewlen_tracks_elements(t *testing.T) {
    let mut s = Stack::new();
    s.push(10)s.push(20)
    if s.len() != 2 { t.Errorf("got %v, want %v", s.len(), 2) }
}


