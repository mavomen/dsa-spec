// ========== Generated tests ==========

func Testthree_vertex_graph(t *testing.T) {
	let n = 3;
	let mut graph = vec![vec![None; n]; n]graph[0][0] = Some(0); graph[0][1] = Some(3); graph[0][2] = Some(8)graph[1][0] = Some(3); graph[1][1] = Some(0); graph[1][2] = Some(1)graph[2][0] = Some(8); graph[2][1] = Some(1); graph[2][2] = Some(0)let dist = floyd_warshall(&graph)
	if dist[0][1] != Some(3) { t.Errorf("got %v, want %v", dist[0][1], Some(3)) }if dist[0][2] != Some(4) { t.Errorf("got %v, want %v", dist[0][2], Some(4)) }if dist[1][2] != Some(1) { t.Errorf("got %v, want %v", dist[1][2], Some(1)) }if dist[2][0] != Some(4) { t.Errorf("got %v, want %v", dist[2][0], Some(4)) }if dist[0][0] != Some(0) { t.Errorf("got %v, want %v", dist[0][0], Some(0)) }
}

func Testsingle_vertex(t *testing.T) {
	let n = 1;
	let graph = vec![vec![Some(0)]]let dist = floyd_warshall(&graph)
	if dist[0][0] != Some(0) { t.Errorf("got %v, want %v", dist[0][0], Some(0)) }
}

func Testdisconnected_vertices(t *testing.T) {
	let n = 4;
	let mut graph = vec![vec![None; n]; n]graph[0][0] = Some(0); graph[0][1] = Some(2)graph[1][0] = Some(2); graph[1][1] = Some(0)graph[2][2] = Some(0)graph[3][3] = Some(0)let dist = floyd_warshall(&graph)
	if dist[0][1] != Some(2) { t.Errorf("got %v, want %v", dist[0][1], Some(2)) }if !(dist[0][2].is_none()) { t.Errorf("assertion failed: dist[0][2].is_none()") }if !(dist[2][3].is_none()) { t.Errorf("assertion failed: dist[2][3].is_none()") }
}

