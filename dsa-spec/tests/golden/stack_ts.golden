// ========== Generated Jest tests ==========

describe('push_and_pop', () => {
    it('should work', () => {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(1);s.push(2);
        // Assertions
        expect(s.pop()).toBe(Some(2));expect(s.pop()).toBe(Some(1));expect(s.is_empty()).toBe(true);
    });
});

describe('peek_returns_top', () => {
    it('should work', () => {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(42);
        // Assertions
        expect(s.peek()).toBe(Some(&42));
    });
});

describe('pop_empty_returns_none', () => {
    it('should work', () => {
        // Setup
        let mut s = Stack::<i32>::new();
        // Actions
        
        // Assertions
        expect(s.pop()).toBe(None);
    });
});

describe('len_tracks_elements', () => {
    it('should work', () => {
        // Setup
        let mut s = Stack::new();
        // Actions
        s.push(10);s.push(20);
        // Assertions
        expect(s.len()).toBe(2);
    });
});

