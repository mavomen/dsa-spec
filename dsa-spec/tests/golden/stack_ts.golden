// --- Stack.ts ---
/**
 * Stack
 * Time complexity: O(1) push/pop, O(n) search

 * Space complexity: O(n)


 * Invariants:
 * - length >= 0

 */


export class Stack<T> {

    
    public items: T[];
    
}

// --- Stack_new.ts ---
/**
 * Stack.new

 * @returns Self



 * Postconditions:
 * - length == 0

 */

import { Stack } from './stack';


(Stack.prototype as any).new = function <T>(): Self {

    
    throw new Error('Not implemented');
};

// ========== Generated tests ==========

describe('push_and_pop', () => {
    it('should pass', () => {
        let mut s = Stack::new();
        s.push(1);s.push(2);
        expect(s.pop()).toBe(Some(2));expect(s.pop()).toBe(Some(1));expect(s.is_empty()).toBe(true);
    });
});

describe('peek_returns_top', () => {
    it('should pass', () => {
        let mut s = Stack::new();
        s.push(42);
        expect(s.peek()).toBe(Some(&42));
    });
});

describe('pop_empty_returns_none', () => {
    it('should pass', () => {
        let mut s = Stack::<i32>::new();
        
        expect(s.pop()).toBe(None);
    });
});

describe('len_tracks_elements', () => {
    it('should pass', () => {
        let mut s = Stack::new();
        s.push(10);s.push(20);
        expect(s.len()).toBe(2);
    });
});


