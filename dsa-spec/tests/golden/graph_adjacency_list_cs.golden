// --- Graph.cs ---
/// <summary>
/// Graph

/// Time complexity: O(V+E) for traversal


/// Space complexity: O(V+E)


/// Invariants:

/// - all edges reference valid vertices

/// - vertex count >= 0


/// </summary>

using System;
using System.Collections.Generic;
using System.Linq;

namespace Graph
{
    public partial class Graph<T>
    where T : Clone, Hash, Eq

    {
        
        public HashMap<T, Vec<T>> AdjacencyList { get; set; }
        
        public bool Directed { get; set; }
        
    }
}

// --- Graph.New.cs ---
namespace Graph
{
    public partial class Graph<T>
    where T : Clone, Hash, Eq

    {
        /// <summary>
        /// New.
        /// </summary>
        
        /// <param name="directed">bool.</param>
        
        
        /// <returns>Self.</returns>
        
        
        
        /// <remarks>
        /// Postconditions:
        
        /// - vertex_count == 0
        
        /// - edge_count == 0
        
        /// </remarks>
        
        
        public Self New(bool directed)
        {
            
            throw new NotImplementedException();
        }
    }
}

// ========== Generated xUnit tests ==========

public class Graphadd_vertex_and_edgeTests
{
    [Fact]
    public void add_vertex_and_edge_Test()
    {
        let mut g = Graph::new(false);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        Assert.IsTrue(g.has_vertex(1));Assert.IsTrue(g.has_vertex(2));Assert.IsTrue(g.has_edge(1, 2));Assert.AreEqual(g.vertex_count(), 2);Assert.AreEqual(g.edge_count(), 1);
    }
}

public class Graphundirected_graph_symmetric_edgesTests
{
    [Fact]
    public void undirected_graph_symmetric_edges_Test()
    {
        let mut g = Graph::new(false);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        Assert.IsTrue(g.has_edge(1, 2));Assert.IsTrue(g.has_edge(2, 1));
    }
}

public class Graphdirected_graph_no_symmetryTests
{
    [Fact]
    public void directed_graph_no_symmetry_Test()
    {
        let mut g = Graph::new(true);
        g.add_vertex(1);g.add_vertex(2);g.add_edge(1, 2);
        Assert.IsTrue(g.has_edge(1, 2));Assert.IsTrue(!g.has_edge(2, 1));
    }
}


